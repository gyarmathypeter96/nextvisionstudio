---
import type { LandingPageData } from "../../data/landingPages";

interface Props {
  page: LandingPageData;
}

const { page } = Astro.props;
---

<section class:list={["landing-proof", `landing-proof--${page.kind}`]} id="landing-work" aria-labelledby="landing-proof-title">
  <div class="landing-proof__inner">
    <header>
      <div class="landing-proof__kicker">{page.proofKicker}</div>
      <h2 id="landing-proof-title">{page.proofTitle}</h2>
      <p>{page.proofText}</p>
    </header>

    <div class="landing-proof__grid">
      {
        page.proofItems.map((item, index) => (
          <article class:list={[{ "landing-proof__card--visual": item.image }] }>
            {item.image ? (
              <img
                src={item.image}
                alt={item.alt}
                width={item.width}
                height={item.height}
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="landing-proof__abstract" aria-hidden="true">
                <div class="landing-proof__abstract-bar"><i></i><i></i><i></i></div>
                <span></span><span></span><span></span>
                <strong>0{index + 1}</strong>
              </div>
            )}
            <div class="landing-proof__shade" aria-hidden="true"></div>
            <div class="landing-proof__copy">
              <span>{item.tag}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </article>
        ))
      }
    </div>

    <a class="landing-proof__link" href={page.relatedLinks[0].href}>
      {page.relatedLinks[0].label} <span aria-hidden="true">↗</span>
    </a>
  </div>
</section>

<style>
  .landing-proof,
  .landing-proof * {
    box-sizing: border-box;
  }

  .landing-proof {
    position: relative;
    padding: 118px 24px 124px;
    overflow: hidden;
    background:
      radial-gradient(circle at 84% 42%, rgba(155, 210, 255, 0.075), transparent 28%),
      #111111;
    color: #ffffff;
    scroll-margin-top: 94px;
  }

  .landing-proof__inner {
    width: min(100%, 1160px);
    margin: 0 auto;
  }

  .landing-proof header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.56fr);
    align-items: end;
    margin-bottom: 54px;
    gap: 50px;
  }

  .landing-proof__kicker {
    grid-column: 1 / -1;
    margin-bottom: -26px;
    color: #cfeaff;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .landing-proof h2 {
    margin: 0;
    font-size: clamp(48px, 6.5vw, 80px);
    font-weight: 950;
    letter-spacing: -0.07em;
    line-height: 0.94;
    text-wrap: balance;
  }

  .landing-proof header p {
    margin: 0;
    color: rgba(255, 255, 255, 0.58);
    font-size: 16px;
    line-height: 1.65;
  }

  .landing-proof__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .landing-proof article {
    position: relative;
    min-height: 460px;
    overflow: hidden;
    border: 1px solid rgba(180, 220, 255, 0.14);
    border-radius: 26px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.065), rgba(255, 255, 255, 0.018)),
      #15191d;
    box-shadow: 0 25px 65px rgba(0, 0, 0, 0.28);
    transition: transform 240ms ease, border-color 240ms ease, box-shadow 240ms ease;
  }

  .landing-proof article:hover {
    border-color: rgba(180, 220, 255, 0.29);
    box-shadow:
      0 30px 70px rgba(0, 0, 0, 0.36),
      0 0 34px rgba(155, 210, 255, 0.08);
    transform: translateY(-5px);
  }

  .landing-proof article > img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 500ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .landing-proof--video article > img,
  .landing-proof--social article > img {
    object-position: center;
  }

  .landing-proof article:hover > img {
    transform: scale(1.035);
  }

  .landing-proof__shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5, 8, 10, 0.94), rgba(5, 8, 10, 0.08) 72%);
    pointer-events: none;
  }

  .landing-proof--web .landing-proof__shade {
    background: linear-gradient(to top, rgba(5, 8, 10, 0.88), transparent 75%);
  }

  .landing-proof__copy {
    position: absolute;
    z-index: 2;
    right: 27px;
    bottom: 27px;
    left: 27px;
  }

  .landing-proof__copy > span {
    display: inline-flex;
    margin-bottom: 13px;
    color: #9bd2ff;
    font-size: 9px;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .landing-proof__copy h3 {
    margin: 0 0 9px;
    font-size: 26px;
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .landing-proof__copy p {
    margin: 0;
    color: rgba(255, 255, 255, 0.57);
    font-size: 13px;
    line-height: 1.55;
  }

  .landing-proof__abstract {
    position: absolute;
    top: 38px;
    right: 28px;
    left: 28px;
    height: 245px;
    padding: 22px;
    overflow: hidden;
    border: 1px solid rgba(180, 220, 255, 0.12);
    border-radius: 20px;
    background:
      radial-gradient(circle at 80% 20%, rgba(155, 210, 255, 0.12), transparent 30%),
      #10151a;
  }

  .landing-proof__abstract-bar {
    display: flex;
    margin-bottom: 54px;
    gap: 5px;
  }

  .landing-proof__abstract-bar i {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.24);
  }

  .landing-proof__abstract > span {
    display: block;
    width: 78%;
    height: 8px;
    margin-top: 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.13);
  }

  .landing-proof__abstract > span:nth-of-type(2) {
    width: 58%;
  }

  .landing-proof__abstract > span:nth-of-type(3) {
    width: 35%;
    background: rgba(155, 210, 255, 0.28);
  }

  .landing-proof__abstract > strong {
    position: absolute;
    right: 19px;
    bottom: 13px;
    color: rgba(207, 234, 255, 0.12);
    font-size: 82px;
    letter-spacing: -0.08em;
  }

  .landing-proof__link {
    display: flex;
    width: fit-content;
    align-items: center;
    margin: 32px auto 0;
    padding: 13px 19px;
    gap: 10px;
    border: 1px solid rgba(180, 220, 255, 0.17);
    border-radius: 999px;
    background: rgba(155, 210, 255, 0.045);
    color: #cfeaff;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.11em;
    text-decoration: none;
    text-transform: uppercase;
    transition: transform 200ms ease, border-color 200ms ease;
  }

  .landing-proof__link:hover {
    border-color: rgba(180, 220, 255, 0.35);
    transform: translateY(-2px);
  }

  .landing-proof__link:focus-visible {
    outline: 2px solid #cfeaff;
    outline-offset: 4px;
  }

  @media (max-width: 900px) {
    .landing-proof header {
      grid-template-columns: 1fr;
      gap: 21px;
    }

    .landing-proof__kicker {
      margin-bottom: 0;
    }

    .landing-proof__grid {
      grid-template-columns: 1fr;
    }

    .landing-proof article {
      min-height: 500px;
    }
  }

  @media (max-width: 560px) {
    .landing-proof {
      padding: 88px 16px 94px;
    }

    .landing-proof h2 {
      font-size: clamp(41px, 12.5vw, 56px);
    }

    .landing-proof article {
      min-height: 440px;
      border-radius: 22px;
    }

    .landing-proof__copy {
      right: 22px;
      bottom: 22px;
      left: 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .landing-proof article,
    .landing-proof article > img,
    .landing-proof__link {
      transition: none;
    }
  }
</style>
