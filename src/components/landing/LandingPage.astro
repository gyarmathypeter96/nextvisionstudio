---
import LandingHero from "./LandingHero.astro";
import LandingTrust from "./LandingTrust.astro";
import LandingValue from "./LandingValue.astro";
import LandingDeliverables from "./LandingDeliverables.astro";
import LandingProof from "./LandingProof.astro";
import LandingProcess from "./LandingProcess.astro";
import LandingFAQ from "./LandingFAQ.astro";
import LandingLeadForm from "./LandingLeadForm.astro";
import type { LandingPageData } from "../../data/landingPages";

interface Props {
  page: LandingPageData;
}

const { page } = Astro.props;
const canonical = `https://www.nextvisionstudio.com/${page.slug}/`;

const landingSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      url: canonical,
      name: page.metaTitle,
      description: page.metaDescription,
      about: { "@id": `${canonical}#service` },
      isPartOf: { "@id": "https://www.nextvisionstudio.com/#website" },
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      name: page.serviceType,
      description: page.schemaDescription,
      serviceType: page.serviceType,
      url: canonical,
      areaServed: {
        "@type": "City",
        name: "Dublin",
      },
      provider: {
        "@type": "ProfessionalService",
        "@id": "https://www.nextvisionstudio.com/#business",
        name: "NextVision Studio",
        url: "https://www.nextvisionstudio.com/",
        telephone: "+353894797055",
        address: {
          "@type": "PostalAddress",
          addressLocality: "Dublin",
          addressCountry: "IE",
        },
      },
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: `${page.serviceType} services`,
        itemListElement: page.deliverables.map((item) => ({
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: item.title,
            description: item.text,
          },
        })),
      },
    },
    {
      "@type": "FAQPage",
      "@id": `${canonical}#faq`,
      mainEntity: page.faq.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: "https://www.nextvisionstudio.com/",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: page.eyebrow,
          item: canonical,
        },
      ],
    },
  ],
};
---

<main class="landing-page">
  <LandingHero page={page} />
  <LandingTrust line={page.trustLine} />
  <LandingValue page={page} />
  <LandingDeliverables page={page} />
  <LandingProof page={page} />
  <LandingProcess page={page} />
  <LandingFAQ page={page} />
  <LandingLeadForm page={page} />
</main>

<script type="application/ld+json" set:html={JSON.stringify(landingSchema)} />

<style>
  .landing-page {
    width: 100%;
    overflow: hidden;
    background: #111111;
  }
</style>
