---
import type { LandingPageData } from "../../data/landingPages";

interface Props {
  page: LandingPageData;
}

const { page } = Astro.props;
---

<section class:list={["landing-hero", `landing-hero--${page.kind}`]} aria-labelledby="landing-title">
  <div class="landing-hero__grid" aria-hidden="true"></div>
  <div class="landing-hero__inner">
    <div class="landing-hero__copy">
      <div class="landing-hero__eyebrow">{page.eyebrow}</div>
      <h1 id="landing-title">
        {page.headlineStart} <span>{page.headlineAccent}</span>{page.headlineEnd && ` ${page.headlineEnd}`}
      </h1>
      <p class="landing-hero__lead">{page.lead}</p>

      <div class="landing-hero__actions">
        <a class="landing-hero__primary" href="#landing-contact">{page.ctaLabel}</a>
        <a class="landing-hero__secondary" href="#landing-work">See relevant work</a>
      </div>

      <ul class="landing-hero__points" aria-label="Service highlights">
        {page.heroPoints.map((point) => <li>{point}</li>)}
      </ul>
    </div>

    <div class="landing-hero__visual" aria-label={`${page.eyebrow} visual preview`}>
      {
        page.kind === "web" ? (
          <div class="landing-browser" aria-hidden="true">
            <div class="landing-browser__bar">
              <i></i><i></i><i></i><span>premium business website</span>
            </div>
            <div class="landing-browser__content">
              <small>Clear value proposition</small>
              <strong>Your business,<br />easy to trust.</strong>
              <p>Focused content. Fast pages. One obvious next step.</p>
              <span>Start a project</span>
            </div>
            <div class="landing-browser__cards">
              <div><small>01</small><strong>Clarity</strong></div>
              <div><small>02</small><strong>Speed</strong></div>
              <div><small>03</small><strong>Enquiries</strong></div>
            </div>
          </div>
        ) : (
          <div class="landing-media">
            <img
              src={page.heroImage?.src}
              alt={page.heroImage?.alt}
              width={page.heroImage?.width}
              height={page.heroImage?.height}
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
            <div class="landing-media__overlay" aria-hidden="true"></div>
            <div class="landing-media__label">
              <small>NextVision Studio</small>
              <strong>{page.eyebrow}</strong>
            </div>
          </div>
        )
      }

      <div class="landing-hero__float landing-hero__float--one">Dublin</div>
      <div class="landing-hero__float landing-hero__float--two">Strategy led</div>
    </div>
  </div>

  <a class="landing-hero__scroll" href="#landing-value" aria-label="Continue to service details">
    <span>Explore</span>
    <i aria-hidden="true"></i>
  </a>
</section>

<style>
  .landing-hero,
  .landing-hero * {
    box-sizing: border-box;
  }

  .landing-hero {
    position: relative;
    min-height: 100svh;
    padding: 156px 24px 106px;
    overflow: hidden;
    background:
      radial-gradient(circle at 78% 42%, rgba(155, 210, 255, 0.13), transparent 31%),
      radial-gradient(circle at 12% 78%, rgba(77, 119, 151, 0.08), transparent 27%),
      linear-gradient(180deg, #0b0e11 0%, #10151a 66%, #111111 100%);
    color: #ffffff;
  }

  .landing-hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(207, 234, 255, 0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(207, 234, 255, 0.022) 1px, transparent 1px);
    background-size: 76px 76px;
    mask-image: linear-gradient(to bottom, #000, transparent 92%);
    pointer-events: none;
  }

  .landing-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(380px, 0.72fr);
    align-items: center;
    width: min(100%, 1200px);
    min-height: calc(100svh - 262px);
    margin: 0 auto;
    gap: clamp(58px, 8vw, 110px);
  }

  .landing-hero__eyebrow,
  .landing-hero__float {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 15px;
    border: 1px solid rgba(180, 220, 255, 0.25);
    border-radius: 999px;
    background: rgba(155, 210, 255, 0.075);
    color: #cfeaff;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .landing-hero__eyebrow {
    margin-bottom: 25px;
  }

  .landing-hero h1 {
    max-width: 790px;
    margin: 0;
    color: #ffffff;
    font-size: clamp(62px, 7.7vw, 106px);
    font-weight: 950;
    letter-spacing: -0.077em;
    line-height: 0.86;
    text-wrap: balance;
  }

  .landing-hero h1 span {
    color: #cfeaff;
    text-shadow: 0 0 48px rgba(155, 210, 255, 0.18);
  }

  .landing-hero__lead {
    max-width: 700px;
    margin: 29px 0 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: clamp(17px, 1.8vw, 20px);
    font-weight: 500;
    line-height: 1.63;
  }

  .landing-hero__actions {
    display: flex;
    flex-wrap: wrap;
    margin-top: 34px;
    gap: 12px;
  }

  .landing-hero__actions a {
    display: inline-flex;
    min-height: 55px;
    align-items: center;
    justify-content: center;
    padding: 0 24px;
    border-radius: 999px;
    color: #ffffff;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-decoration: none;
    text-transform: uppercase;
    transition: transform 220ms ease, border-color 220ms ease, background 220ms ease;
  }

  .landing-hero__primary {
    border: 1px solid rgba(207, 234, 255, 0.38);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.18), rgba(155, 210, 255, 0.11)),
      rgba(255, 255, 255, 0.055);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.27),
      0 18px 42px rgba(0, 0, 0, 0.3),
      0 0 30px rgba(155, 210, 255, 0.1);
  }

  .landing-hero__secondary {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.025);
  }

  .landing-hero__actions a:hover {
    border-color: rgba(207, 234, 255, 0.5);
    background-color: rgba(155, 210, 255, 0.1);
    transform: translateY(-2px);
  }

  .landing-hero__actions a:focus-visible,
  .landing-hero__scroll:focus-visible {
    outline: 2px solid #cfeaff;
    outline-offset: 4px;
  }

  .landing-hero__points {
    display: flex;
    flex-wrap: wrap;
    margin: 31px 0 0;
    padding: 0;
    gap: 10px 18px;
    list-style: none;
  }

  .landing-hero__points li {
    position: relative;
    padding-left: 15px;
    color: rgba(255, 255, 255, 0.49);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.045em;
  }

  .landing-hero__points li::before {
    content: "";
    position: absolute;
    top: 0.48em;
    left: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #9bd2ff;
    box-shadow: 0 0 10px rgba(155, 210, 255, 0.55);
  }

  .landing-hero__visual {
    position: relative;
    width: min(100%, 470px);
    margin: 0 auto;
  }

  .landing-media,
  .landing-browser {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(180, 220, 255, 0.24);
    border-radius: 36px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.025)),
      #141a1f;
    box-shadow:
      0 34px 90px rgba(0, 0, 0, 0.54),
      0 0 70px rgba(155, 210, 255, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.13);
    transform: rotate(1.5deg);
  }

  .landing-media {
    padding: 10px;
  }

  .landing-media img {
    display: block;
    width: 100%;
    height: clamp(460px, 58vw, 570px);
    border-radius: 27px;
    object-fit: cover;
  }

  .landing-hero--video .landing-media img {
    object-position: center;
  }

  .landing-hero--social .landing-media img {
    object-position: center 35%;
  }

  .landing-media__overlay {
    position: absolute;
    inset: 10px;
    border-radius: 27px;
    background: linear-gradient(to top, rgba(4, 7, 9, 0.85), transparent 54%);
  }

  .landing-media__label {
    position: absolute;
    z-index: 1;
    right: 36px;
    bottom: 34px;
    left: 36px;
    display: grid;
    gap: 7px;
  }

  .landing-media__label small {
    color: #cfeaff;
    font-size: 9px;
    font-weight: 900;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .landing-media__label strong {
    font-size: 25px;
    letter-spacing: -0.045em;
  }

  .landing-browser {
    padding: 13px;
    transform: rotate(-1.2deg);
  }

  .landing-browser__bar {
    display: flex;
    height: 39px;
    align-items: center;
    padding: 0 14px;
    gap: 6px;
    border-radius: 24px 24px 0 0;
    background: rgba(255, 255, 255, 0.045);
  }

  .landing-browser__bar i {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.24);
  }

  .landing-browser__bar span {
    margin-left: auto;
    color: rgba(255, 255, 255, 0.34);
    font-size: 8px;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .landing-browser__content {
    min-height: 360px;
    padding: 58px 35px 42px;
    border: 1px solid rgba(180, 220, 255, 0.09);
    border-radius: 0 0 25px 25px;
    background:
      radial-gradient(circle at 82% 22%, rgba(155, 210, 255, 0.16), transparent 29%),
      #10151a;
  }

  .landing-browser__content small {
    color: #9bd2ff;
    font-size: 9px;
    font-weight: 900;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .landing-browser__content strong {
    display: block;
    margin-top: 19px;
    font-size: clamp(34px, 4vw, 50px);
    line-height: 0.94;
    letter-spacing: -0.06em;
  }

  .landing-browser__content p {
    max-width: 310px;
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.5);
    font-size: 12px;
    line-height: 1.6;
  }

  .landing-browser__content > span {
    display: inline-flex;
    margin-top: 27px;
    padding: 10px 17px;
    border: 1px solid rgba(207, 234, 255, 0.28);
    border-radius: 999px;
    background: rgba(155, 210, 255, 0.09);
    color: #ffffff;
    font-size: 8px;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .landing-browser__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 11px;
    gap: 9px;
  }

  .landing-browser__cards div {
    display: grid;
    min-height: 84px;
    align-content: end;
    padding: 13px;
    gap: 5px;
    border: 1px solid rgba(180, 220, 255, 0.1);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.035);
  }

  .landing-browser__cards small {
    color: #9bd2ff;
    font-size: 8px;
  }

  .landing-browser__cards strong {
    font-size: 11px;
  }

  .landing-hero__float {
    position: absolute;
    z-index: 2;
    background: rgba(12, 17, 21, 0.82);
    box-shadow: 0 16px 38px rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(16px);
  }

  .landing-hero__float--one {
    top: 16%;
    left: -34px;
    transform: rotate(-8deg);
  }

  .landing-hero__float--two {
    right: -30px;
    bottom: 17%;
    transform: rotate(7deg);
  }

  .landing-hero__scroll {
    position: absolute;
    z-index: 2;
    bottom: 28px;
    left: 50%;
    display: grid;
    justify-items: center;
    gap: 9px;
    color: rgba(255, 255, 255, 0.4);
    font-size: 8px;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-decoration: none;
    text-transform: uppercase;
    transform: translateX(-50%);
  }

  .landing-hero__scroll i {
    position: relative;
    display: block;
    width: 1px;
    height: 28px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.13);
  }

  .landing-hero__scroll i::after {
    content: "";
    position: absolute;
    top: -100%;
    left: 0;
    width: 100%;
    height: 65%;
    background: #cfeaff;
    animation: landing-scroll 1.8s ease-in-out infinite;
  }

  @keyframes landing-scroll {
    0% { top: -70%; }
    70%, 100% { top: 110%; }
  }

  @media (max-width: 920px) {
    .landing-hero {
      min-height: auto;
      padding: 132px 20px 100px;
    }

    .landing-hero__inner {
      grid-template-columns: 1fr;
      min-height: auto;
      gap: 70px;
    }

    .landing-hero__copy {
      text-align: center;
    }

    .landing-hero__lead {
      margin-right: auto;
      margin-left: auto;
    }

    .landing-hero__actions,
    .landing-hero__points {
      justify-content: center;
    }

    .landing-hero__visual {
      width: min(90%, 470px);
    }

    .landing-hero__scroll {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .landing-hero {
      padding: 116px 16px 84px;
    }

    .landing-hero h1 {
      font-size: clamp(48px, 15vw, 70px);
      line-height: 0.9;
    }

    .landing-hero__lead {
      margin-top: 24px;
      font-size: 16px;
      line-height: 1.58;
    }

    .landing-hero__actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .landing-hero__points {
      display: grid;
      justify-content: start;
      width: fit-content;
      margin-right: auto;
      margin-left: auto;
      text-align: left;
    }

    .landing-hero__visual {
      width: calc(100% - 20px);
    }

    .landing-media,
    .landing-browser {
      border-radius: 28px;
    }

    .landing-media img {
      height: 470px;
      border-radius: 20px;
    }

    .landing-media__overlay {
      border-radius: 20px;
    }

    .landing-browser__content {
      min-height: 330px;
      padding: 46px 23px 35px;
    }

    .landing-browser__cards strong {
      font-size: 9px;
    }

    .landing-hero__float--one {
      left: -10px;
    }

    .landing-hero__float--two {
      right: -10px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .landing-hero__actions a {
      transition: none;
    }

    .landing-hero__scroll i::after {
      animation: none;
    }
  }
</style>
