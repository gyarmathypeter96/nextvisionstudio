---
import type { LandingPageData } from "../../data/landingPages";

interface Props {
  page: LandingPageData;
}

const { page } = Astro.props;
---

<section class="landing-value" id="landing-value" aria-labelledby="landing-value-title">
  <div class="landing-value__inner">
    <div class="landing-value__copy">
      <div class="landing-section-kicker">{page.problemKicker}</div>
      <h2 id="landing-value-title">{page.problemTitle}</h2>
      <p>{page.problemText}</p>
      <a href="#landing-contact">Get a clear recommendation <span aria-hidden="true">→</span></a>
    </div>

    <ol class="landing-value__outcomes">
      {
        page.outcomes.map((outcome, index) => (
          <li>
            <span>0{index + 1}</span>
            <div>
              <h3>{outcome.title}</h3>
              <p>{outcome.text}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .landing-value,
  .landing-value * {
    box-sizing: border-box;
  }

  .landing-value {
    position: relative;
    padding: 118px 24px;
    overflow: hidden;
    background:
      radial-gradient(circle at 13% 60%, rgba(155, 210, 255, 0.075), transparent 29%),
      #111111;
    color: #ffffff;
    scroll-margin-top: 100px;
  }

  .landing-value__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(420px, 1.12fr);
    align-items: center;
    width: min(100%, 1120px);
    margin: 0 auto;
    gap: clamp(54px, 8vw, 104px);
  }

  .landing-section-kicker {
    margin-bottom: 21px;
    color: #cfeaff;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .landing-value h2 {
    margin: 0;
    font-size: clamp(43px, 5.5vw, 70px);
    font-weight: 950;
    letter-spacing: -0.066em;
    line-height: 0.96;
    text-wrap: balance;
  }

  .landing-value__copy > p {
    margin: 25px 0 0;
    color: rgba(255, 255, 255, 0.62);
    font-size: 16px;
    line-height: 1.7;
  }

  .landing-value__copy > a {
    display: inline-flex;
    align-items: center;
    margin-top: 26px;
    gap: 10px;
    color: #cfeaff;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.09em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .landing-value__copy > a span {
    font-size: 17px;
    transition: transform 180ms ease;
  }

  .landing-value__copy > a:hover span {
    transform: translateX(5px);
  }

  .landing-value__copy > a:focus-visible {
    outline: 2px solid #cfeaff;
    outline-offset: 5px;
  }

  .landing-value__outcomes {
    display: grid;
    margin: 0;
    padding: 0;
    gap: 12px;
    list-style: none;
  }

  .landing-value__outcomes li {
    display: grid;
    grid-template-columns: 50px 1fr;
    min-height: 130px;
    align-items: center;
    padding: 24px;
    gap: 20px;
    border: 1px solid rgba(180, 220, 255, 0.12);
    border-radius: 22px;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.018)),
      #15191d;
    box-shadow: 0 22px 52px rgba(0, 0, 0, 0.2);
    transition: transform 220ms ease, border-color 220ms ease, background 220ms ease;
  }

  .landing-value__outcomes li:hover {
    border-color: rgba(180, 220, 255, 0.25);
    background-color: rgba(155, 210, 255, 0.04);
    transform: translateY(-3px);
  }

  .landing-value__outcomes li > span {
    display: grid;
    width: 50px;
    height: 50px;
    place-items: center;
    border: 1px solid rgba(180, 220, 255, 0.2);
    border-radius: 16px;
    background: rgba(155, 210, 255, 0.08);
    color: #cfeaff;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.08em;
  }

  .landing-value__outcomes h3 {
    margin: 0 0 7px;
    font-size: 20px;
    letter-spacing: -0.035em;
  }

  .landing-value__outcomes p {
    margin: 0;
    color: rgba(255, 255, 255, 0.52);
    font-size: 14px;
    line-height: 1.55;
  }

  @media (max-width: 880px) {
    .landing-value__inner {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .landing-value {
      padding: 88px 16px;
    }

    .landing-value h2 {
      font-size: clamp(40px, 12.4vw, 55px);
    }

    .landing-value__outcomes li {
      grid-template-columns: 42px 1fr;
      min-height: 120px;
      padding: 20px;
      gap: 15px;
    }

    .landing-value__outcomes li > span {
      width: 42px;
      height: 42px;
      border-radius: 14px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .landing-value__copy > a span,
    .landing-value__outcomes li {
      transition: none;
    }
  }
</style>
