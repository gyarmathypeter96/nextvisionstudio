---
const steps = [
  {
    number: "01",
    title: "Discover",
    text: "We learn about your business, audience, offer and the result you want to achieve.",
    tags: ["Goals", "Audience", "Priorities"],
  },
  {
    number: "02",
    title: "Plan",
    text: "We shape the content plan, campaign structure or website journey before production begins.",
    tags: ["Clear scope", "Creative direction", "Timeline"],
  },
  {
    number: "03",
    title: "Create",
    text: "We film, photograph, design, write and build the assets your project needs.",
    tags: ["Production", "Design", "Development"],
  },
  {
    number: "04",
    title: "Launch",
    text: "Your content, advertising campaign or website goes live in the right formats and channels.",
    tags: ["Delivery", "Publishing", "Campaign setup"],
  },
  {
    number: "05",
    title: "Improve",
    text: "We review performance, learn from real results and refine the next step for stronger growth.",
    tags: ["Measure", "Optimise", "Scale"],
  },
];
---

<section class="services-process" id="our-process" aria-labelledby="process-title" data-services-process>
  <div class="services-process__inner">
    <header class="services-process__header">
      <div class="services-process__kicker">Our process</div>
      <h2 id="process-title">A Clear Path From Idea to Growth</h2>
      <p>
        The same simple process keeps content, advertising and website projects
        focused, organised and easy to understand.
      </p>
    </header>

    <div class="services-process__roadmap">
      <div class="services-process__line" aria-hidden="true">
        <span></span>
      </div>

      {
        steps.map((step, index) => (
          <article
            class:list={[
              "process-step",
              index % 2 === 0 ? "process-step--left" : "process-step--right",
            ]}
            data-process-step
          >
            <div class="process-step__dot" aria-hidden="true"></div>
            <div class="process-step__card">
              <div class="process-step__number">{step.number}</div>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
              <ul aria-label={`${step.title} includes`}>
                {step.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            </div>
          </article>
        ))
      }
    </div>

    <aside class="services-process__cta" aria-label="Start a project with NextVision Studio">
      <div class="services-process__cta-label">Ready when you are</div>
      <h3>Let’s Build the Right System for Your Business</h3>
      <p>
        Tell us what you want to improve and we’ll recommend the clearest mix of
        content, advertising and web support.
      </p>
      <a href="/contact/"><span>Start your project</span></a>
    </aside>
  </div>
</section>

<script>
  const initialiseServicesProcess = () => {
    document.querySelectorAll<HTMLElement>("[data-services-process]").forEach((process) => {
      if (process.dataset.processReady === "true") return;
      process.dataset.processReady = "true";

      const steps = process.querySelectorAll<HTMLElement>("[data-process-step]");
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (reducedMotion || !("IntersectionObserver" in window)) {
        steps.forEach((step) => step.classList.add("is-visible"));
      } else {
        process.classList.add("is-enhanced");
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.18 },
        );

        steps.forEach((step) => observer.observe(step));
      }

      const updateProgress = () => {
        const roadmap = process.querySelector<HTMLElement>(".services-process__roadmap");
        if (!roadmap) return;

        const rect = roadmap.getBoundingClientRect();
        const start = window.innerHeight * 0.58;
        const distance = Math.max(rect.height - window.innerHeight * 0.28, 1);
        const progress = Math.min(Math.max((start - rect.top) / distance, 0), 1);
        process.style.setProperty("--process-progress", `${progress * 100}%`);
      };

      updateProgress();
      window.addEventListener("scroll", updateProgress, { passive: true });
      window.addEventListener("resize", updateProgress);
    });
  };

  initialiseServicesProcess();
  document.addEventListener("astro:page-load", initialiseServicesProcess);
</script>

<style>
  .services-process,
  .services-process * {
    box-sizing: border-box;
  }

  .services-process {
    --process-progress: 0%;
    position: relative;
    padding: 122px 24px 130px;
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 38%, rgba(155, 210, 255, 0.075), transparent 32%),
      linear-gradient(to bottom, #111111, #10151a 48%, #111111);
    color: #ffffff;
  }

  .services-process::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(207, 234, 255, 0.018) 1px, transparent 1px),
      linear-gradient(90deg, rgba(207, 234, 255, 0.018) 1px, transparent 1px);
    background-size: 82px 82px;
    mask-image: radial-gradient(circle at center, #000, transparent 78%);
    pointer-events: none;
  }

  .services-process__inner {
    position: relative;
    z-index: 1;
    width: min(100%, 1120px);
    margin: 0 auto;
  }

  .services-process__header {
    width: min(100%, 860px);
    margin: 0 auto 72px;
    text-align: center;
  }

  .services-process__kicker,
  .process-step__number,
  .services-process__cta-label {
    display: inline-flex;
    margin-bottom: 19px;
    padding: 9px 15px;
    border: 1px solid rgba(180, 220, 255, 0.24);
    border-radius: 999px;
    background: rgba(155, 210, 255, 0.07);
    color: #cfeaff;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .services-process__header h2 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(46px, 7vw, 82px);
    font-weight: 950;
    letter-spacing: -0.07em;
    line-height: 0.94;
    text-wrap: balance;
  }

  .services-process__header p {
    width: min(100%, 690px);
    margin: 25px auto 0;
    color: rgba(255, 255, 255, 0.64);
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.6;
    text-wrap: balance;
  }

  .services-process__roadmap {
    position: relative;
    width: min(100%, 1040px);
    margin: 0 auto;
  }

  .services-process__line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 3px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    box-shadow: inset 0 0 8px rgba(0, 0, 0, 0.35);
    transform: translateX(-50%);
  }

  .services-process__line span {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--process-progress);
    border-radius: 999px;
    background: linear-gradient(to bottom, #d7efff, #9bd2ff, #63839c);
    box-shadow:
      0 0 18px rgba(155, 210, 255, 0.55),
      0 0 45px rgba(155, 210, 255, 0.2);
  }

  .process-step {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 250px;
    align-items: center;
  }

  .services-process.is-enhanced .process-step {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 600ms ease, transform 600ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .services-process.is-enhanced .process-step.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .process-step--left .process-step__card {
    grid-column: 1;
    margin-right: 74px;
  }

  .process-step--right .process-step__card {
    grid-column: 2;
    margin-left: 74px;
  }

  .process-step__dot {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 2;
    width: 20px;
    height: 20px;
    border: 3px solid rgba(207, 234, 255, 0.3);
    border-radius: 50%;
    background: #141a1f;
    box-shadow: 0 0 0 8px rgba(155, 210, 255, 0.045);
    transform: translate(-50%, -50%);
    transition: border-color 350ms ease, background 350ms ease, box-shadow 350ms ease;
  }

  .process-step.is-visible .process-step__dot {
    border-color: rgba(255, 255, 255, 0.68);
    background: linear-gradient(135deg, #d7efff, #9bd2ff, #63839c);
    box-shadow:
      0 0 0 9px rgba(155, 210, 255, 0.07),
      0 0 24px rgba(155, 210, 255, 0.42);
  }

  .process-step__card {
    position: relative;
    padding: 27px;
    overflow: hidden;
    border: 1px solid rgba(180, 220, 255, 0.13);
    border-radius: 25px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.065), rgba(255, 255, 255, 0.018)),
      rgba(20, 26, 31, 0.91);
    box-shadow:
      0 23px 65px rgba(0, 0, 0, 0.34),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    transition: border-color 250ms ease, box-shadow 250ms ease, transform 250ms ease;
  }

  .process-step__card::after {
    content: "";
    position: absolute;
    top: -70px;
    right: -60px;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(155, 210, 255, 0.1), transparent 68%);
    pointer-events: none;
  }

  .process-step__card:hover {
    border-color: rgba(180, 220, 255, 0.26);
    box-shadow:
      0 28px 75px rgba(0, 0, 0, 0.4),
      0 0 31px rgba(155, 210, 255, 0.09);
    transform: translateY(-4px);
  }

  .process-step__number {
    margin-bottom: 17px;
    padding: 8px 11px;
    font-size: 9px;
  }

  .process-step h3 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(29px, 3.4vw, 42px);
    font-weight: 900;
    letter-spacing: -0.055em;
    line-height: 0.95;
    text-transform: uppercase;
  }

  .process-step p {
    margin: 14px 0 0;
    color: rgba(255, 255, 255, 0.61);
    font-size: 15px;
    line-height: 1.58;
  }

  .process-step ul {
    display: flex;
    margin: 18px 0 0;
    padding: 0;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
  }

  .process-step li {
    padding: 8px 10px;
    border: 1px solid rgba(180, 220, 255, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.045);
    color: rgba(255, 255, 255, 0.66);
    font-size: 10px;
    font-weight: 750;
  }

  .services-process__cta {
    width: min(100%, 900px);
    margin: 86px auto 0;
    padding: clamp(33px, 5vw, 52px);
    overflow: hidden;
    border: 1px solid rgba(180, 220, 255, 0.18);
    border-radius: 31px;
    background:
      radial-gradient(circle at 50% 0%, rgba(155, 210, 255, 0.13), transparent 52%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.018)),
      rgba(18, 23, 27, 0.9);
    box-shadow:
      0 30px 90px rgba(0, 0, 0, 0.43),
      0 0 50px rgba(155, 210, 255, 0.07);
    text-align: center;
  }

  .services-process__cta h3 {
    width: min(100%, 760px);
    margin: 0 auto;
    color: #ffffff;
    font-size: clamp(36px, 5.5vw, 65px);
    font-weight: 950;
    letter-spacing: -0.07em;
    line-height: 0.95;
    text-wrap: balance;
  }

  .services-process__cta p {
    width: min(100%, 650px);
    margin: 21px auto 0;
    color: rgba(255, 255, 255, 0.63);
    font-size: 16px;
    line-height: 1.58;
    text-wrap: balance;
  }

  .services-process__cta a {
    position: relative;
    display: inline-flex;
    min-width: 210px;
    min-height: 57px;
    margin-top: 28px;
    padding: 0 29px;
    overflow: hidden;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(207, 234, 255, 0.32);
    border-radius: 999px;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.18), rgba(155, 210, 255, 0.1)),
      rgba(255, 255, 255, 0.07);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.28),
      0 20px 48px rgba(0, 0, 0, 0.33);
    color: #ffffff;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.07em;
    text-decoration: none;
    text-transform: uppercase;
    transition: box-shadow 230ms ease, transform 230ms ease;
  }

  .services-process__cta a::after {
    content: "";
    position: absolute;
    top: -80%;
    left: -90%;
    width: 70%;
    height: 260%;
    background: linear-gradient(120deg, transparent, rgba(255, 255, 255, 0.44), transparent);
    opacity: 0.45;
    transform: rotate(18deg);
    transition: left 700ms ease;
  }

  .services-process__cta a span {
    position: relative;
    z-index: 1;
  }

  .services-process__cta a:hover {
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.34),
      0 0 34px rgba(155, 210, 255, 0.14),
      0 23px 52px rgba(0, 0, 0, 0.38);
    transform: translateY(-3px);
  }

  .services-process__cta a:hover::after {
    left: 130%;
  }

  .services-process__cta a:focus-visible {
    outline: 2px solid #cfeaff;
    outline-offset: 4px;
  }

  @media (max-width: 820px) {
    .services-process__line {
      left: 15px;
      transform: none;
    }

    .process-step {
      grid-template-columns: 1fr;
      min-height: auto;
      margin-bottom: 24px;
      padding-left: 49px;
    }

    .process-step--left .process-step__card,
    .process-step--right .process-step__card {
      grid-column: 1;
      margin: 0;
    }

    .process-step__dot {
      top: 28px;
      left: 15px;
      transform: translate(-50%, 0);
    }
  }

  @media (max-width: 600px) {
    .services-process {
      padding: 88px 15px 96px;
    }

    .services-process__header {
      margin-bottom: 52px;
    }

    .services-process__header h2 {
      font-size: clamp(40px, 13vw, 57px);
    }

    .process-step {
      padding-left: 40px;
    }

    .process-step__card {
      padding: 22px 20px;
      border-radius: 21px;
    }

    .services-process__cta {
      margin-top: 58px;
      padding: 34px 20px 29px;
      border-radius: 25px;
    }

    .services-process__cta a {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .services-process.is-enhanced .process-step {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .process-step__card,
    .services-process__cta a,
    .services-process__cta a::after {
      transition: none;
    }
  }
</style>
