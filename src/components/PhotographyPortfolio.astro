---
const photos = [
  {
    src: "/images/photography/event-photography-dublin.webp",
    width: 1440,
    height: 1800,
    title: "Event Photography",
    description: "Live moments, energy and atmosphere",
    alt: "Live event photography in Dublin by NextVision Studio",
    layout: "large",
  },
  {
    src: "/images/photography/creative-portrait-photography-dublin.webp",
    width: 1013,
    height: 1800,
    title: "Portrait Photography",
    description: "Creative portraits with personality",
    alt: "Creative portrait photography for brands in Dublin by NextVision Studio",
  },
  {
    src: "/images/photography/drone-aerial-photography-dublin.webp",
    width: 1350,
    height: 1800,
    title: "Drone Photography",
    description: "Aerial views with cinematic scale",
    alt: "Aerial drone photography and cinematic destination visuals by NextVision Studio",
  },
  {
    src: "/images/photography/product-photography-dublin.webp",
    width: 1013,
    height: 1800,
    title: "Product Photography",
    description: "Clean visuals for modern brands",
    alt: "Professional product photography in Dublin by NextVision Studio",
  },
  {
    src: "/images/photography/hospitality-brand-photography-dublin.webp",
    width: 1200,
    height: 1800,
    title: "Hospitality Photography",
    description: "Details, mood and brand identity",
    alt: "Hospitality and drinks brand photography in Dublin by NextVision Studio",
  },
  {
    src: "/images/photography/brand-photography-social-content-dublin.webp",
    width: 1200,
    height: 1800,
    title: "Brand Photography",
    description: "Premium content made to stand out",
    alt: "Brand photography and social media content creation in Dublin",
  },
  {
    src: "/images/photography/automotive-photography-dublin.webp",
    width: 1200,
    height: 1800,
    title: "Automotive Content",
    description: "Premium details and lifestyle visuals",
    alt: "Automotive photography and branded content creation in Dublin",
  },
  {
    src: "/images/photography/food-drink-photography-dublin.webp",
    width: 1200,
    height: 1800,
    title: "Food & Drink",
    description: "Restaurant, menu and campaign content",
    alt: "Food and drink photography for Dublin restaurants and hospitality brands",
  },
  {
    src: "/images/photography/corporate-photography-dublin.webp",
    width: 1200,
    height: 1800,
    title: "Corporate Photography",
    description: "Professional people and business visuals",
    alt: "Professional corporate and business photography in Dublin",
  },
  {
    src: "/images/photography/automotive-detail-photography-dublin.webp",
    width: 1800,
    height: 1013,
    title: "Automotive Detail",
    description: "Sharp, clean and cinematic imagery",
    alt: "Cinematic automotive detail photography in Dublin by NextVision Studio",
    layout: "wide",
  },
];

const gallerySchema = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  name: "NextVision Studio Photography Portfolio Dublin",
  description:
    "A portfolio of event, brand, product, food, corporate and automotive photography by NextVision Studio in Dublin.",
  url: "https://nextvisionstudio.com/#photography-portfolio",
  associatedMedia: photos.map((photo) => ({
    "@type": "ImageObject",
    name: photo.title,
    caption: photo.alt,
    contentUrl: `https://nextvisionstudio.com${photo.src}`,
    width: photo.width,
    height: photo.height,
    creator: {
      "@type": "Organization",
      name: "NextVision Studio",
      url: "https://nextvisionstudio.com/",
    },
  })),
};
---

<section
  class="photo-gallery"
  id="photography-portfolio"
  aria-labelledby="photography-portfolio-title"
  data-photo-gallery
>
  <header class="photo-gallery__header">
    <div class="photo-gallery__kicker">Photography Dublin</div>
    <h2 id="photography-portfolio-title">Photography Portfolio</h2>
    <p>
      Professional event, brand, product and corporate photography for Dublin
      businesses that need clean, premium visual content.
    </p>
  </header>

  <div class="photo-gallery__grid">
    {
      photos.map((photo) => (
        <button
          class:list={[
            "photo-gallery__card",
            photo.layout && `photo-gallery__card--${photo.layout}`,
          ]}
          type="button"
          aria-label={`View ${photo.title} image`}
          data-photo-src={photo.src}
          data-photo-alt={photo.alt}
          data-photo-title={photo.title}
          data-photo-width={photo.width}
          data-photo-height={photo.height}
        >
          <img
            src={photo.src}
            width={photo.width}
            height={photo.height}
            alt={photo.alt}
            loading="lazy"
            decoding="async"
            sizes="(max-width: 640px) calc(100vw - 32px), (max-width: 1024px) calc(50vw - 35px), 285px"
          />
          <span class="photo-gallery__shade" aria-hidden="true"></span>
          <span class="photo-gallery__copy">
            <strong>{photo.title}</strong>
            <span>{photo.description}</span>
          </span>
          <span class="photo-gallery__expand" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M9 4H4v5M15 4h5v5M9 20H4v-5M15 20h5v-5" />
            </svg>
          </span>
        </button>
      ))
    }
  </div>

  <dialog class="photo-lightbox" aria-label="Photography portfolio image" data-photo-dialog>
    <button
      class="photo-lightbox__close"
      type="button"
      aria-label="Close image"
      data-photo-close
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="m6 6 12 12M18 6 6 18" />
      </svg>
    </button>
    <figure>
      <img src="" alt="" width="1800" height="1200" data-photo-full />
      <figcaption data-photo-caption></figcaption>
    </figure>
  </dialog>

  <script type="application/ld+json" set:html={JSON.stringify(gallerySchema)} />
</section>

<script>
  const setupPhotoGalleries = () => {
    document.querySelectorAll<HTMLElement>("[data-photo-gallery]").forEach((gallery) => {
      if (gallery.dataset.ready === "true") return;
      gallery.dataset.ready = "true";

      const dialog = gallery.querySelector<HTMLDialogElement>("[data-photo-dialog]");
      const fullImage = gallery.querySelector<HTMLImageElement>("[data-photo-full]");
      const caption = gallery.querySelector<HTMLElement>("[data-photo-caption]");
      const closeButton = gallery.querySelector<HTMLButtonElement>("[data-photo-close]");
      let lastTrigger: HTMLButtonElement | null = null;
      let activePhotoWidth = 0;
      let activePhotoHeight = 0;

      const sizeLightbox = () => {
        if (!dialog || !fullImage || !activePhotoWidth || !activePhotoHeight) return;

        const frameSize = 20;
        const maxImageWidth = Math.max(260, window.innerWidth - 56);
        const maxImageHeight = Math.max(260, window.innerHeight - 96);
        const scale = Math.min(
          1,
          maxImageWidth / activePhotoWidth,
          maxImageHeight / activePhotoHeight,
        );
        const displayWidth = Math.round(activePhotoWidth * scale);
        const displayHeight = Math.round(activePhotoHeight * scale);

        fullImage.style.width = `${displayWidth}px`;
        fullImage.style.height = `${displayHeight}px`;
        dialog.style.width = `${displayWidth + frameSize}px`;
      };

      const closeDialog = () => {
        if (dialog?.open) dialog.close();
      };

      gallery.querySelectorAll<HTMLButtonElement>("[data-photo-src]").forEach((card) => {
        card.addEventListener("click", () => {
          if (!dialog || !fullImage) return;

          const src = card.dataset.photoSrc;
          const alt = card.dataset.photoAlt ?? "NextVision Studio photography portfolio";
          const title = card.dataset.photoTitle ?? "Photography portfolio";
          const width = Number(card.dataset.photoWidth);
          const height = Number(card.dataset.photoHeight);
          if (!src) return;

          lastTrigger = card;
          activePhotoWidth = width;
          activePhotoHeight = height;
          fullImage.src = src;
          fullImage.alt = alt;
          fullImage.width = width;
          fullImage.height = height;
          if (caption) caption.textContent = title;
          sizeLightbox();
          document.documentElement.classList.add("photo-lightbox-open");
          dialog.showModal();
        });
      });

      closeButton?.addEventListener("click", closeDialog);
      dialog?.addEventListener("click", (event) => {
        if (event.target === dialog) closeDialog();
      });
      dialog?.addEventListener("close", () => {
        document.documentElement.classList.remove("photo-lightbox-open");
        if (fullImage) {
          fullImage.removeAttribute("src");
          fullImage.alt = "";
          fullImage.removeAttribute("style");
        }
        dialog.removeAttribute("style");
        activePhotoWidth = 0;
        activePhotoHeight = 0;
        if (caption) caption.textContent = "";
        lastTrigger?.focus();
      });
      window.addEventListener("resize", sizeLightbox, { passive: true });
    });
  };

  setupPhotoGalleries();
  document.addEventListener("astro:page-load", setupPhotoGalleries);
</script>

<style>
  .photo-gallery,
  .photo-gallery * {
    box-sizing: border-box;
  }

  :global(html.photo-lightbox-open) {
    overflow: hidden;
  }

  .photo-gallery {
    position: relative;
    width: 100%;
    margin: -1px 0 0;
    padding: 110px 24px 120px;
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.055);
    background:
      radial-gradient(circle at 50% 19%, rgba(93, 163, 213, 0.11), transparent 27%),
      linear-gradient(to bottom, #111111 0%, #10151a 43%, #111111 100%);
    color: #ffffff;
  }

  .photo-gallery__header {
    position: relative;
    z-index: 1;
    width: min(100%, 900px);
    margin: 0 auto 54px;
    text-align: center;
  }

  .photo-gallery__kicker {
    display: inline-flex;
    margin-bottom: 20px;
    padding: 10px 17px;
    border: 1px solid rgba(180, 220, 255, 0.27);
    border-radius: 999px;
    background: rgba(155, 210, 255, 0.075);
    color: #cfeaff;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.13em;
    line-height: 1;
    text-transform: uppercase;
  }

  .photo-gallery__header h2 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(44px, 5.8vw, 76px);
    font-weight: 900;
    letter-spacing: -0.06em;
    line-height: 0.95;
    text-wrap: balance;
  }

  .photo-gallery__header p {
    width: min(100%, 720px);
    margin: 23px auto 0;
    color: rgba(255, 255, 255, 0.63);
    font-size: clamp(16px, 1.7vw, 19px);
    font-weight: 500;
    line-height: 1.58;
    text-wrap: balance;
  }

  .photo-gallery__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-auto-rows: 230px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 17px;
    width: min(100%, 1180px);
    margin: 0 auto;
  }

  .photo-gallery__card {
    position: relative;
    min-width: 0;
    padding: 0;
    overflow: hidden;
    border: 1px solid rgba(180, 220, 255, 0.11);
    border-radius: 22px;
    background: #172027;
    box-shadow:
      0 18px 52px rgba(0, 0, 0, 0.35),
      0 0 28px rgba(155, 210, 255, 0.035);
    color: #ffffff;
    cursor: zoom-in;
    font: inherit;
    text-align: left;
    transition:
      border-color 300ms ease,
      box-shadow 300ms ease,
      transform 300ms ease;
  }

  .photo-gallery__card--large {
    grid-column: span 2;
    grid-row: span 2;
  }

  .photo-gallery__card--wide {
    grid-column: span 2;
  }

  .photo-gallery__card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      filter 500ms ease,
      transform 500ms ease;
  }

  .photo-gallery__shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(3, 5, 6, 0.9), rgba(3, 5, 6, 0.22) 52%, transparent 76%);
    pointer-events: none;
  }

  .photo-gallery__copy {
    position: absolute;
    z-index: 1;
    right: 20px;
    bottom: 19px;
    left: 20px;
    display: grid;
    gap: 5px;
  }

  .photo-gallery__copy strong {
    color: #ffffff;
    font-size: clamp(18px, 1.65vw, 22px);
    font-weight: 850;
    letter-spacing: -0.035em;
    line-height: 1.05;
  }

  .photo-gallery__copy > span {
    padding-right: 38px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 13px;
    font-weight: 550;
    line-height: 1.35;
  }

  .photo-gallery__expand {
    position: absolute;
    z-index: 2;
    right: 16px;
    bottom: 16px;
    display: grid;
    width: 35px;
    height: 35px;
    place-items: center;
    border: 1px solid rgba(207, 234, 255, 0.26);
    border-radius: 50%;
    background: rgba(15, 21, 26, 0.7);
    color: #d7efff;
    opacity: 0;
    transform: scale(0.86);
    transition:
      opacity 250ms ease,
      transform 250ms ease;
  }

  .photo-gallery__expand svg {
    width: 17px;
    height: 17px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.7;
  }

  .photo-gallery__card:hover {
    border-color: rgba(180, 220, 255, 0.3);
    box-shadow:
      0 0 34px rgba(155, 210, 255, 0.14),
      0 28px 70px rgba(0, 0, 0, 0.46);
    transform: translateY(-5px);
  }

  .photo-gallery__card:hover img {
    filter: brightness(1.07) saturate(1.04);
    transform: scale(1.055);
  }

  .photo-gallery__card:hover .photo-gallery__expand,
  .photo-gallery__card:focus-visible .photo-gallery__expand {
    opacity: 1;
    transform: scale(1);
  }

  .photo-gallery__card:focus-visible,
  .photo-lightbox__close:focus-visible {
    outline: 3px solid #cfeaff;
    outline-offset: 4px;
  }

  .photo-lightbox {
    width: auto;
    max-width: calc(100vw - 36px);
    max-height: calc(100vh - 36px);
    padding: 9px;
    overflow: visible;
    border: 1px solid rgba(180, 220, 255, 0.23);
    border-radius: 24px;
    background: #080b0d;
    box-shadow:
      0 0 90px rgba(0, 0, 0, 0.88),
      0 0 50px rgba(155, 210, 255, 0.12);
    color: #ffffff;
  }

  .photo-lightbox::backdrop {
    background: rgba(2, 4, 5, 0.9);
    backdrop-filter: blur(13px);
  }

  .photo-lightbox figure {
    display: grid;
    margin: 0;
  }

  .photo-lightbox img {
    display: block;
    max-width: none;
    max-height: none;
    border-radius: 16px;
    object-fit: contain;
  }

  .photo-lightbox figcaption {
    min-height: 39px;
    padding: 11px 8px 2px;
    color: rgba(255, 255, 255, 0.72);
    font-size: 14px;
    font-weight: 750;
  }

  .photo-lightbox__close {
    position: absolute;
    z-index: 2;
    top: -16px;
    right: -16px;
    display: grid;
    width: 48px;
    height: 48px;
    padding: 0;
    place-items: center;
    border: 1px solid rgba(210, 235, 255, 0.36);
    border-radius: 50%;
    background: rgba(25, 33, 39, 0.97);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.42);
    color: #ffffff;
    cursor: pointer;
  }

  .photo-lightbox__close svg {
    width: 23px;
    height: 23px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-width: 1.8;
  }

  @media (max-width: 1024px) {
    .photo-gallery__grid {
      grid-auto-rows: 225px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .photo-gallery__card--large {
      grid-column: span 2;
      grid-row: span 2;
    }

    .photo-gallery__card--wide {
      grid-column: span 2;
    }
  }

  @media (max-width: 640px) {
    .photo-gallery {
      padding: 88px 16px 96px;
    }

    .photo-gallery__header {
      margin-bottom: 42px;
    }

    .photo-gallery__header h2 {
      font-size: clamp(42px, 12vw, 56px);
    }

    .photo-gallery__grid {
      grid-auto-rows: 260px;
      grid-template-columns: 1fr;
      grid-template-rows: 330px;
      gap: 14px;
    }

    .photo-gallery__card--large,
    .photo-gallery__card--wide {
      grid-column: span 1;
      grid-row: span 1;
    }

    .photo-gallery__card {
      border-radius: 18px;
    }

    .photo-gallery__copy {
      right: 17px;
      bottom: 17px;
      left: 17px;
    }

    .photo-gallery__copy strong {
      font-size: 20px;
    }

    .photo-gallery__expand {
      opacity: 1;
      transform: scale(1);
    }

    .photo-lightbox {
      max-width: calc(100vw - 24px);
      max-height: calc(100vh - 24px);
      padding: 6px;
      border-radius: 18px;
    }

    .photo-lightbox img {
      border-radius: 13px;
    }

    .photo-lightbox__close {
      top: -13px;
      right: -7px;
      width: 45px;
      height: 45px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-gallery__card,
    .photo-gallery__card img,
    .photo-gallery__expand {
      transition: none;
    }
  }
</style>
