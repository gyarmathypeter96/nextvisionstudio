---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel: string;
  secondaryHref: string;
}

const {
  eyebrow,
  title,
  description,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
} = Astro.props;
---

<main class="page-placeholder">
  <div class="page-placeholder__glow" aria-hidden="true"></div>
  <div class="page-placeholder__grid" aria-hidden="true"></div>

  <section class="page-placeholder__content" aria-labelledby="page-title">
    <div class="page-placeholder__eyebrow">{eyebrow}</div>
    <h1 id="page-title">{title}</h1>
    <p>{description}</p>

    <div class="page-placeholder__actions">
      <a class="page-placeholder__primary" href={primaryHref}>{primaryLabel}</a>
      <a class="page-placeholder__secondary" href={secondaryHref}>{secondaryLabel}</a>
    </div>

    <div class="page-placeholder__status">
      <span aria-hidden="true"></span>
      Dedicated page in development
    </div>
  </section>
</main>

<style>
  .page-placeholder,
  .page-placeholder * {
    box-sizing: border-box;
  }

  .page-placeholder {
    position: relative;
    isolation: isolate;
    display: grid;
    min-height: 100svh;
    padding: 150px 24px 72px;
    overflow: hidden;
    place-items: center;
    background:
      radial-gradient(circle at 50% 25%, rgba(155, 210, 255, 0.08), transparent 29%),
      linear-gradient(150deg, #111111 0%, #10151a 48%, #111111 100%);
    color: #ffffff;
    text-align: center;
  }

  .page-placeholder__glow {
    position: absolute;
    top: 34%;
    left: 50%;
    z-index: -1;
    width: min(900px, 96vw);
    height: 430px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(155, 210, 255, 0.13), transparent 68%);
    filter: blur(54px);
    pointer-events: none;
    transform: translate(-50%, -50%);
  }

  .page-placeholder__grid {
    position: absolute;
    inset: 0;
    z-index: -2;
    background-image:
      linear-gradient(rgba(207, 234, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(207, 234, 255, 0.025) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: radial-gradient(circle at center, #000 0%, transparent 72%);
    pointer-events: none;
  }

  .page-placeholder__content {
    width: min(100%, 850px);
    padding: clamp(34px, 6vw, 66px);
    border: 1px solid rgba(207, 234, 255, 0.16);
    border-radius: 34px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.018)),
      rgba(15, 20, 24, 0.74);
    box-shadow:
      0 34px 100px rgba(0, 0, 0, 0.48),
      0 0 70px rgba(155, 210, 255, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px) saturate(145%);
    -webkit-backdrop-filter: blur(20px) saturate(145%);
  }

  .page-placeholder__eyebrow {
    display: inline-flex;
    margin-bottom: 23px;
    padding: 9px 15px;
    border: 1px solid rgba(155, 210, 255, 0.24);
    border-radius: 999px;
    background: rgba(155, 210, 255, 0.07);
    color: #cfeaff;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .page-placeholder h1 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(52px, 8vw, 94px);
    font-weight: 950;
    letter-spacing: -0.07em;
    line-height: 0.94;
    text-wrap: balance;
  }

  .page-placeholder p {
    width: min(100%, 650px);
    margin: 27px auto 0;
    color: rgba(255, 255, 255, 0.66);
    font-size: clamp(16px, 2vw, 19px);
    font-weight: 520;
    line-height: 1.65;
    text-wrap: balance;
  }

  .page-placeholder__actions {
    display: flex;
    margin-top: 34px;
    align-items: center;
    justify-content: center;
    gap: 11px;
  }

  .page-placeholder__actions a {
    display: inline-flex;
    min-height: 54px;
    padding: 0 25px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 850;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: transform 220ms ease, box-shadow 220ms ease, background 220ms ease;
  }

  .page-placeholder__primary {
    border: 1px solid rgba(207, 234, 255, 0.36);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.17), rgba(155, 210, 255, 0.1)),
      rgba(255, 255, 255, 0.07);
    box-shadow:
      0 18px 42px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.26);
    color: #ffffff;
  }

  .page-placeholder__secondary {
    border: 1px solid rgba(207, 234, 255, 0.12);
    background: rgba(255, 255, 255, 0.035);
    color: rgba(255, 255, 255, 0.75);
  }

  .page-placeholder__actions a:hover {
    background-color: rgba(155, 210, 255, 0.1);
    box-shadow: 0 0 32px rgba(155, 210, 255, 0.11);
    transform: translateY(-2px);
  }

  .page-placeholder__actions a:focus-visible {
    outline: 2px solid #cfeaff;
    outline-offset: 4px;
  }

  .page-placeholder__status {
    display: inline-flex;
    margin-top: 34px;
    align-items: center;
    gap: 9px;
    color: rgba(255, 255, 255, 0.42);
    font-size: 11px;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .page-placeholder__status span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #9bd2ff;
    box-shadow: 0 0 13px rgba(155, 210, 255, 0.72);
  }

  @media (max-width: 600px) {
    .page-placeholder {
      padding: 112px 14px 40px;
    }

    .page-placeholder__content {
      padding: 37px 19px 30px;
      border-radius: 26px;
    }

    .page-placeholder h1 {
      font-size: clamp(43px, 14vw, 62px);
      letter-spacing: -0.06em;
    }

    .page-placeholder__actions {
      flex-direction: column;
    }

    .page-placeholder__actions a {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .page-placeholder__actions a {
      transition: none;
    }
  }
</style>
