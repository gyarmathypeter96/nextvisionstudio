---
const pathname = Astro.url.pathname;
const isHome = pathname === "/";

const navigation = [
  { label: "Home", href: "/" },
  { label: "Services", href: "/services/" },
  { label: "About", href: "/about/" },
  { label: "Contact Us", href: "/contact/", featured: true },
];

const isCurrent = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header
  class:list={["site-header", { "site-header--home": isHome }]}
  data-site-header
>
  <div class="site-header__inner">
    <a class="site-header__brand" href="/" aria-label="NextVision Studio home">
      <img
        src="/images/brand/nextvision-studio-logo.png"
        width="500"
        height="500"
        alt="NextVision Studio"
        decoding="async"
      />
    </a>

    <button
      class="site-header__toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-navigation"
      aria-label="Open navigation menu"
      data-menu-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav
      class="site-header__nav"
      id="primary-navigation"
      aria-label="Primary navigation"
      data-primary-navigation
    >
      {
        navigation.map((item) => (
          <a
            class:list={[
              "site-header__link",
              { "site-header__link--featured": item.featured },
              { "is-current": isCurrent(item.href) },
            ]}
            href={item.href}
            aria-current={isCurrent(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const initialiseHeaders = () => {
    document.querySelectorAll<HTMLElement>("[data-site-header]").forEach((header) => {
      if (header.dataset.headerReady === "true") return;
      header.dataset.headerReady = "true";

      const toggle = header.querySelector<HTMLButtonElement>("[data-menu-toggle]");
      const navigation = header.querySelector<HTMLElement>("[data-primary-navigation]");

      const updateScrolledState = () => {
        header.classList.toggle("is-scrolled", window.scrollY > 18);
      };

      const closeMenu = () => {
        header.classList.remove("is-menu-open");
        toggle?.setAttribute("aria-expanded", "false");
        toggle?.setAttribute("aria-label", "Open navigation menu");
        document.documentElement.classList.remove("navigation-is-open");
      };

      const openMenu = () => {
        header.classList.add("is-menu-open");
        toggle?.setAttribute("aria-expanded", "true");
        toggle?.setAttribute("aria-label", "Close navigation menu");
        document.documentElement.classList.add("navigation-is-open");
      };

      toggle?.addEventListener("click", () => {
        header.classList.contains("is-menu-open") ? closeMenu() : openMenu();
      });

      navigation?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeMenu);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && header.classList.contains("is-menu-open")) {
          closeMenu();
          toggle?.focus();
        }
      });

      window.addEventListener("scroll", updateScrolledState, { passive: true });
      window.addEventListener("resize", () => {
        if (window.innerWidth > 820) closeMenu();
      });

      updateScrolledState();
    });
  };

  initialiseHeaders();
  document.addEventListener("astro:page-load", initialiseHeaders);
</script>

<style>
  .site-header,
  .site-header * {
    box-sizing: border-box;
  }

  .site-header {
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    z-index: 1000;
    padding: max(14px, env(safe-area-inset-top)) 20px 0;
    pointer-events: none;
  }

  .site-header__inner {
    position: relative;
    display: flex;
    width: min(100%, 1320px);
    min-height: 78px;
    margin: 0 auto;
    padding: 4px 6px 4px 10px;
    align-items: center;
    justify-content: space-between;
    border: 1px solid transparent;
    border-radius: 24px;
    pointer-events: auto;
    transition:
      background 240ms ease,
      border-color 240ms ease,
      box-shadow 240ms ease,
      min-height 240ms ease;
  }

  .site-header:not(.site-header--home) .site-header__inner,
  .site-header.is-scrolled .site-header__inner,
  .site-header.is-menu-open .site-header__inner {
    border-color: rgba(207, 234, 255, 0.15);
    background: rgba(10, 14, 17, 0.76);
    box-shadow:
      0 18px 48px rgba(0, 0, 0, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(22px) saturate(155%);
    -webkit-backdrop-filter: blur(22px) saturate(155%);
  }

  .site-header.is-scrolled .site-header__inner {
    min-height: 68px;
  }

  .site-header__brand {
    display: grid;
    width: 72px;
    height: 72px;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 18px;
    text-decoration: none;
    transition: transform 220ms ease;
  }

  .site-header__brand img {
    display: block;
    width: 72px;
    height: 72px;
    object-fit: contain;
    mix-blend-mode: screen;
    filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.35));
  }

  .site-header__brand:hover {
    transform: translateY(-2px) scale(1.025);
  }

  .site-header__brand:focus-visible,
  .site-header__toggle:focus-visible,
  .site-header__link:focus-visible {
    outline: 2px solid #cfeaff;
    outline-offset: 4px;
  }

  .site-header__nav {
    display: flex;
    padding: 6px;
    align-items: center;
    gap: 3px;
    border: 1px solid rgba(207, 234, 255, 0.12);
    border-radius: 999px;
    background: rgba(10, 14, 17, 0.48);
    box-shadow:
      0 14px 40px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(18px) saturate(145%);
    -webkit-backdrop-filter: blur(18px) saturate(145%);
  }

  .site-header__link {
    position: relative;
    display: inline-flex;
    min-height: 43px;
    padding: 0 18px;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 13px;
    font-weight: 750;
    letter-spacing: 0.025em;
    text-decoration: none;
    transition:
      color 180ms ease,
      background 180ms ease,
      border-color 180ms ease,
      transform 180ms ease;
  }

  .site-header__link:hover,
  .site-header__link.is-current {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.075);
  }

  .site-header__link:hover {
    transform: translateY(-1px);
  }

  .site-header__link.is-current::after {
    content: "";
    position: absolute;
    right: 19px;
    bottom: 5px;
    left: 19px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #9bd2ff, transparent);
    box-shadow: 0 0 9px rgba(155, 210, 255, 0.6);
  }

  .site-header__link--featured {
    border-color: rgba(207, 234, 255, 0.24);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.13), rgba(155, 210, 255, 0.08)),
      rgba(255, 255, 255, 0.04);
    color: #ffffff;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.17);
  }

  .site-header__toggle {
    display: none;
    width: 48px;
    height: 48px;
    padding: 0;
    place-items: center;
    border: 1px solid rgba(207, 234, 255, 0.2);
    border-radius: 50%;
    background: rgba(13, 18, 22, 0.7);
    color: #ffffff;
    cursor: pointer;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.09);
  }

  .site-header__toggle span {
    position: absolute;
    width: 19px;
    height: 1.5px;
    border-radius: 999px;
    background: currentColor;
    transition: transform 220ms ease, opacity 180ms ease;
  }

  .site-header__toggle span:nth-child(1) {
    transform: translateY(-6px);
  }

  .site-header__toggle span:nth-child(3) {
    transform: translateY(6px);
  }

  .site-header.is-menu-open .site-header__toggle span:nth-child(1) {
    transform: rotate(45deg);
  }

  .site-header.is-menu-open .site-header__toggle span:nth-child(2) {
    opacity: 0;
  }

  .site-header.is-menu-open .site-header__toggle span:nth-child(3) {
    transform: rotate(-45deg);
  }

  @media (max-width: 820px) {
    .site-header {
      padding: max(10px, env(safe-area-inset-top)) 12px 0;
    }

    .site-header__inner {
      min-height: 66px;
      padding: 3px 5px 3px 8px;
      border-radius: 21px;
    }

    .site-header__brand,
    .site-header__brand img {
      width: 60px;
      height: 60px;
    }

    .site-header__brand {
      border-radius: 15px;
    }

    .site-header__toggle {
      position: relative;
      display: grid;
    }

    .site-header__nav {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      left: 0;
      display: grid;
      padding: 12px;
      gap: 7px;
      border-radius: 22px;
      background: rgba(10, 14, 17, 0.94);
      box-shadow:
        0 30px 80px rgba(0, 0, 0, 0.58),
        inset 0 1px 0 rgba(255, 255, 255, 0.09);
      opacity: 0;
      pointer-events: none;
      transform: translateY(-10px) scale(0.98);
      transform-origin: top;
      transition:
        opacity 180ms ease,
        transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .site-header.is-menu-open .site-header__nav {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0) scale(1);
    }

    .site-header__link {
      width: 100%;
      min-height: 54px;
      justify-content: flex-start;
      padding: 0 19px;
      border-radius: 15px;
      font-size: 15px;
    }

    .site-header__link.is-current::after {
      top: 50%;
      right: 15px;
      bottom: auto;
      left: auto;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #9bd2ff;
      box-shadow: 0 0 13px rgba(155, 210, 255, 0.72);
      transform: translateY(-50%);
    }

    .site-header__link--featured {
      border-color: rgba(207, 234, 255, 0.2);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header__inner,
    .site-header__brand,
    .site-header__link,
    .site-header__nav,
    .site-header__toggle span {
      transition: none;
    }
  }

  :global(html.navigation-is-open) {
    overflow: hidden;
  }
</style>
