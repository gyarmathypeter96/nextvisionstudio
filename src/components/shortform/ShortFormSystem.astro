  <ol class="sf-system__grid">
    {steps.map((step) => (
      <li>
        <span>{step.number}</span>
        <h3>{step.title}</h3>
        <p>{step.text}</p>
      </li>
    ))}
  </ol>

  <p class="sf-system__close">
    Filming is a skill. Distribution is a system. <strong>We do both.</strong>
  </p>
</section>
