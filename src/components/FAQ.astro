---
const faqItems = [
  {
    question: "What services does NextVision Studio offer?",
    answer:
      "NextVision Studio helps Dublin businesses with professional videography, photography, short-form social media content, social media management, Meta Ads, Google Ads and premium website design and development. Services can be booked individually or combined into one clear content and marketing system.",
  },
  {
    question: "Do you provide videography services in Dublin?",
    answer:
      "Yes. NextVision Studio provides videography and video production in Dublin for businesses, brands, events, restaurants and local service companies. We plan, film and edit professional video content for websites, social media, advertising and promotional campaigns.",
  },
  {
    question: "What types of business videos do you create?",
    answer:
      "We create brand videos, event coverage, promotional videos, interviews, testimonials, product and hospitality content, Reels, TikTok videos, YouTube Shorts and paid social advertising creatives. Each project is planned around the audience, platform and business goal.",
  },
  {
    question: "How much does professional videography cost in Dublin?",
    answer:
      "Videography costs depend on the filming time, location, production requirements, number and length of edits, and whether photography or ongoing social media content is included. Send us a short project brief and we will recommend the most suitable approach with a clear quote.",
  },
  {
    question: "What is full-service social media content creation?",
    answer:
      "Full-service social media content creation covers the complete process: ideas, planning, filming, photography and edited short-form videos. Your business receives consistent, branded content designed for platforms such as Instagram, Facebook, TikTok, LinkedIn and YouTube.",
  },
  {
    question: "Can you manage Meta Ads and Google Ads?",
    answer:
      "Yes. We support businesses with Meta Ads and Google Ads, including campaign planning, audience targeting, creative production, messaging and ongoing improvement. The objective can be brand awareness, website traffic, leads, enquiries or sales depending on your business.",
  },
  {
    question: "Do you design and develop websites?",
    answer:
      "Yes. We design and develop fast, premium websites for Dublin businesses. Each website is built around clear service messaging, responsive mobile design, local SEO, strong calls to action and contact forms that make it easy for potential customers to enquire.",
  },
  {
    question: "Can you provide photography as well as video?",
    answer:
      "Yes. We provide event, brand, product, food and drink, corporate and automotive photography. Video and photography can be produced together so your website, social media channels and advertising use a consistent visual style.",
  },
  {
    question: "Who does NextVision Studio work with?",
    answer:
      "We work with Dublin businesses, local service providers, restaurants, hospitality brands, events, creators, small businesses and growing companies. The service is suitable for any organisation that needs stronger visual content, social media or a more professional website.",
  },
  {
    question: "How do I start a project with NextVision Studio?",
    answer:
      "Send a short message through the quote form with information about your business, your goal and what you would like to create. We will review the details, recommend the right combination of services and contact you to discuss the next step.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<section class="faq" id="faq" aria-labelledby="faq-title">
  <div class="faq__inner">
    <header class="faq__header">
      <div class="faq__kicker">Frequently Asked Questions</div>
      <h2 id="faq-title">FAQ for Dublin Businesses</h2>
      <p>
        Clear answers about videography, video production, photography, social
        media, advertising and website design in Dublin.
      </p>
    </header>

    <div class="faq__grid">
      {
        faqItems.map((item, index) => (
          <details class="faq__item" name="nextvision-faq" open={index === 0}>
            <summary>{item.question}</summary>
            <div class="faq__answer">
              <p>{item.answer}</p>
            </div>
          </details>
        ))
      }
    </div>

    <aside class="faq__cta" aria-labelledby="faq-cta-title">
      <h3 id="faq-cta-title">Ready to build a stronger online presence?</h3>
      <p>
        Tell us what your business needs and we’ll recommend the right mix of
        video, photography, social media, advertising and website design.
      </p>
      <a class="faq__button" href="#contact-form">Get a free quote</a>
    </aside>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</section>

<style>
  .faq,
  .faq * {
    box-sizing: border-box;
  }

  .faq {
    position: relative;
    width: 100%;
    margin: -1px 0 0;
    padding: 112px 24px 120px;
    overflow: hidden;
    border-top: 1px solid rgba(255, 255, 255, 0.055);
    background:
      radial-gradient(circle at 18% 18%, rgba(155, 210, 255, 0.09), transparent 30%),
      radial-gradient(circle at 82% 76%, rgba(190, 225, 255, 0.055), transparent 30%),
      linear-gradient(to bottom, #111111 0%, #10151a 48%, #111111 100%);
    color: #ffffff;
  }

  .faq__inner {
    width: min(100%, 1120px);
    margin: 0 auto;
  }

  .faq__header {
    width: min(100%, 860px);
    margin: 0 auto 58px;
    text-align: center;
  }

  .faq__kicker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 22px;
    padding: 10px 17px;
    border: 1px solid rgba(180, 220, 255, 0.27);
    border-radius: 999px;
    background: rgba(155, 210, 255, 0.075);
    color: #cfeaff;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.13em;
    line-height: 1;
    text-transform: uppercase;
  }

  .faq__header h2 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(44px, 5.6vw, 74px);
    font-weight: 900;
    letter-spacing: -0.06em;
    line-height: 0.96;
    text-wrap: balance;
  }

  .faq__header p {
    width: min(100%, 760px);
    margin: 24px auto 0;
    color: rgba(255, 255, 255, 0.65);
    font-size: clamp(16px, 1.7vw, 19px);
    font-weight: 500;
    line-height: 1.58;
    text-wrap: balance;
  }

  .faq__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 15px;
    align-items: start;
  }

  .faq__item {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(180, 220, 255, 0.14);
    border-radius: 22px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.065), rgba(255, 255, 255, 0.025)),
      rgba(14, 20, 26, 0.72);
    box-shadow:
      0 20px 58px rgba(0, 0, 0, 0.19),
      inset 0 1px 1px rgba(255, 255, 255, 0.075);
    transition:
      border-color 250ms ease,
      background 250ms ease,
      box-shadow 250ms ease,
      transform 250ms ease;
  }

  .faq__item:hover {
    border-color: rgba(180, 220, 255, 0.27);
    transform: translateY(-2px);
  }

  .faq__item[open] {
    border-color: rgba(180, 220, 255, 0.24);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.082), rgba(255, 255, 255, 0.028)),
      rgba(14, 20, 26, 0.78);
    box-shadow:
      0 24px 66px rgba(0, 0, 0, 0.24),
      0 0 28px rgba(155, 210, 255, 0.045),
      inset 0 1px 1px rgba(255, 255, 255, 0.09);
  }

  .faq__item summary {
    position: relative;
    padding: 23px 60px 23px 23px;
    color: #ffffff;
    cursor: pointer;
    font-size: 17px;
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.3;
    list-style: none;
  }

  .faq__item summary::-webkit-details-marker {
    display: none;
  }

  .faq__item summary::after {
    position: absolute;
    top: 50%;
    right: 20px;
    display: grid;
    width: 31px;
    height: 31px;
    place-items: center;
    border: 1px solid rgba(180, 220, 255, 0.18);
    border-radius: 50%;
    background: rgba(155, 210, 255, 0.1);
    color: #d9eeff;
    content: "+";
    font-size: 19px;
    font-weight: 650;
    line-height: 1;
    transform: translateY(-50%);
    transition:
      background 250ms ease,
      transform 250ms ease;
  }

  .faq__item[open] summary::after {
    background: rgba(155, 210, 255, 0.17);
    content: "−";
  }

  .faq__item summary:focus-visible {
    outline: 3px solid #cfeaff;
    outline-offset: -4px;
    border-radius: 19px;
  }

  .faq__answer {
    padding: 0 23px 24px;
    color: rgba(255, 255, 255, 0.67);
    font-size: 15px;
    font-weight: 480;
    line-height: 1.66;
  }

  .faq__answer p {
    margin: 0;
  }

  .faq__cta {
    width: min(100%, 820px);
    margin: 54px auto 0;
    padding: 35px 28px;
    border: 1px solid rgba(180, 220, 255, 0.15);
    border-radius: 28px;
    background:
      radial-gradient(circle at 50% 0%, rgba(155, 210, 255, 0.12), transparent 38%),
      rgba(255, 255, 255, 0.045);
    box-shadow:
      0 25px 70px rgba(0, 0, 0, 0.25),
      inset 0 1px 1px rgba(255, 255, 255, 0.07);
    text-align: center;
  }

  .faq__cta h3 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(29px, 3.4vw, 43px);
    font-weight: 900;
    letter-spacing: -0.055em;
    line-height: 1.04;
    text-wrap: balance;
  }

  .faq__cta p {
    width: min(100%, 640px);
    margin: 17px auto 0;
    color: rgba(255, 255, 255, 0.65);
    font-size: 16px;
    font-weight: 500;
    line-height: 1.55;
  }

  .faq__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    margin-top: 25px;
    padding: 0 28px;
    border: 1px solid rgba(180, 220, 255, 0.34);
    border-radius: 999px;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.16), rgba(155, 210, 255, 0.1)),
      rgba(255, 255, 255, 0.075);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.24),
      0 18px 42px rgba(0, 0, 0, 0.25);
    color: #ffffff;
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      border-color 250ms ease,
      box-shadow 250ms ease,
      transform 250ms ease;
  }

  .faq__button:hover {
    border-color: rgba(180, 220, 255, 0.48);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.28),
      0 0 34px rgba(155, 210, 255, 0.12),
      0 21px 48px rgba(0, 0, 0, 0.29);
    transform: translateY(-3px);
  }

  .faq__button:focus-visible {
    outline: 3px solid #cfeaff;
    outline-offset: 4px;
  }

  @media (max-width: 900px) {
    .faq__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .faq {
      padding: 88px 16px 94px;
    }

    .faq__header {
      margin-bottom: 42px;
    }

    .faq__header h2 {
      font-size: clamp(42px, 12vw, 55px);
    }

    .faq__header p {
      font-size: 16px;
    }

    .faq__item {
      border-radius: 20px;
    }

    .faq__item summary {
      padding: 20px 54px 20px 19px;
      font-size: 16px;
    }

    .faq__item summary::after {
      right: 17px;
      width: 29px;
      height: 29px;
    }

    .faq__answer {
      padding: 0 19px 21px;
      font-size: 14.5px;
    }

    .faq__cta {
      margin-top: 42px;
      padding: 29px 20px;
      border-radius: 24px;
    }

    .faq__button {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq__item,
    .faq__item summary::after,
    .faq__button {
      transition: none;
    }
  }
</style>
