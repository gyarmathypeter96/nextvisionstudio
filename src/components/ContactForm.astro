---
import { CRM_FORM_ENDPOINT } from "../config/forms";
---

<section class="contact" id="contact-form" aria-labelledby="contact-title">
  <header class="contact__header">
    <div class="contact__kicker">Start a project</div>
    <h2 id="contact-title">Let’s Create Something That Gets Noticed</h2>
    <p>
      Looking for a videographer in Dublin, professional photography, social
      media content or a new website? Tell us what you have in mind and we’ll
      get back to you with the next steps.
    </p>
  </header>

  <form
    class="contact__form"
    action={CRM_FORM_ENDPOINT}
    method="POST"
    data-crm-form
  >
    <input
      type="hidden"
      name="redirect"
      value={"https://www.nextvisionstudio.com/quotesend/?submitted=1&source=homepage-contact"}
    />
    <input
      type="hidden"
      name="subject"
      value="New project enquiry from the NextVision Studio website"
    />
    <input type="hidden" name="from_name" value="NextVision Studio Website" />

    <div class="contact__botcheck" aria-hidden="true">
      <input
        type="checkbox"
        name="botcheck"
        tabindex="-1"
        autocomplete="off"
      />
    </div>

    <div class="contact__field">
      <label for="contact-name">Name</label>
      <input
        id="contact-name"
        type="text"
        name="name"
        placeholder="Your name"
        autocomplete="name"
        required
      />
    </div>

    <div class="contact__field">
      <label for="contact-email">Email</label>
      <input
        id="contact-email"
        type="email"
        name="email"
        placeholder="you@example.com"
        autocomplete="email"
        inputmode="email"
        required
      />
    </div>

    <div class="contact__field">
      <label for="contact-message">Tell us about your project</label>
      <textarea
        id="contact-message"
        name="message"
        placeholder="What would you like to create?"
        rows="6"
        required
      ></textarea>
    </div>

    <button type="submit">
      <span>Get a free quote</span>
    </button>

    <p class="contact__privacy">
      Your details are used only to respond to your enquiry.
    </p>
  </form>
</section>

<style>
  .contact,
  .contact * {
    box-sizing: border-box;
  }

  .contact {
    width: 100%;
    margin: 0;
    padding: 112px 24px 120px;
    background: #111111;
    color: #ffffff;
  }

  .contact__header {
    width: min(100%, 820px);
    margin: 0 auto 54px;
    text-align: center;
  }

  .contact__kicker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 22px;
    padding: 10px 17px;

    border: 1px solid rgba(180, 220, 255, 0.28);
    border-radius: 999px;
    background: rgba(155, 210, 255, 0.08);
    color: #cfeaff;
    font-size: 12px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .contact__header h2 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(42px, 5.7vw, 70px);
    font-weight: 900;
    line-height: 0.96;
    letter-spacing: -0.06em;
    text-wrap: balance;
  }

  .contact__header p {
    width: min(100%, 720px);
    margin: 24px auto 0;
    color: rgba(255, 255, 255, 0.66);
    font-size: clamp(16px, 1.8vw, 19px);
    font-weight: 500;
    line-height: 1.58;
    text-wrap: balance;
  }

  .contact__form {
    width: min(100%, 760px);
    margin: 0 auto;
    padding: 42px;

    border: 1px solid rgba(180, 220, 255, 0.16);
    border-radius: 28px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.025)),
      #171717;
    box-shadow:
      0 24px 80px rgba(0, 0, 0, 0.35),
      0 0 42px rgba(155, 210, 255, 0.05);
  }

  .contact__botcheck {
    display: none;
  }

  .contact__field {
    margin-bottom: 18px;
  }

  .contact__field label {
    display: block;
    margin-bottom: 8px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 14px;
    font-weight: 700;
  }

  .contact__field input,
  .contact__field textarea {
    display: block;
    width: 100%;
    min-height: 54px;
    padding: 15px 18px;

    border: 1px solid rgba(180, 220, 255, 0.14);
    border-radius: 16px;
    outline: none;
    background: rgba(255, 255, 255, 0.055);
    color: #ffffff;
    font: inherit;
    font-size: 16px;
    font-weight: 500;

    transition:
      border-color 250ms ease,
      background 250ms ease,
      box-shadow 250ms ease;
  }

  .contact__field textarea {
    min-height: 150px;
    resize: vertical;
  }

  .contact__field input::placeholder,
  .contact__field textarea::placeholder {
    color: rgba(255, 255, 255, 0.38);
  }

  .contact__field input:focus,
  .contact__field textarea:focus {
    border-color: rgba(155, 210, 255, 0.58);
    background: rgba(255, 255, 255, 0.075);
    box-shadow:
      0 0 0 4px rgba(155, 210, 255, 0.1),
      0 0 24px rgba(155, 210, 255, 0.1);
  }

  .contact__form button {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 58px;
    margin-top: 6px;
    overflow: hidden;

    border: 1px solid rgba(180, 220, 255, 0.32);
    border-radius: 999px;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.16), rgba(155, 210, 255, 0.1)),
      rgba(255, 255, 255, 0.08);
    color: #ffffff;
    cursor: pointer;

    font: inherit;
    font-size: 16px;
    font-weight: 900;
    letter-spacing: 0.055em;
    text-transform: uppercase;

    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.34),
      inset 0 -1px 1px rgba(255, 255, 255, 0.08),
      0 0 28px rgba(155, 210, 255, 0.1),
      0 22px 48px rgba(0, 0, 0, 0.32);

    transition:
      transform 280ms ease,
      background 280ms ease,
      box-shadow 280ms ease;
  }

  .contact__form button::after {
    content: "";
    position: absolute;
    top: -70%;
    left: -90%;
    width: 70%;
    height: 240%;

    background: linear-gradient(
      120deg,
      transparent,
      rgba(255, 255, 255, 0.45),
      transparent
    );
    opacity: 0.45;
    pointer-events: none;
    transform: rotate(18deg);
    transition: left 750ms ease;
  }

  .contact__form button span {
    position: relative;
    z-index: 1;
  }

  .contact__form button:hover {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.22), rgba(155, 210, 255, 0.16)),
      rgba(255, 255, 255, 0.12);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.42),
      0 0 36px rgba(155, 210, 255, 0.18),
      0 26px 56px rgba(0, 0, 0, 0.4);
    transform: translateY(-2px);
  }

  .contact__form button:hover::after {
    left: 130%;
  }

  .contact__form button:focus-visible {
    outline: 2px solid #cfeaff;
    outline-offset: 5px;
  }

  .contact__privacy {
    margin: 16px 0 0;
    color: rgba(255, 255, 255, 0.45);
    font-size: 12px;
    line-height: 1.45;
    text-align: center;
  }

  @media (max-width: 767px) {
    .contact {
      padding: 90px 16px 94px;
    }

    .contact__header {
      margin-bottom: 42px;
    }

    .contact__header h2 {
      font-size: clamp(39px, 11vw, 52px);
    }

    .contact__form {
      padding: 30px 20px;
      border-radius: 24px;
    }

    .contact__field input,
    .contact__field textarea {
      font-size: 16px;
    }

    .contact__form button {
      min-height: 56px;
      font-size: 14px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact__field input,
    .contact__field textarea,
    .contact__form button,
    .contact__form button::after {
      transition: none;
    }
  }
</style>
