---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
  title="Video Marketing & Content Blog Dublin | NextVision Studio"
  description="Practical advice on short-form video production, Reels, social media content, photography and digital growth for Dublin businesses."
  canonical="https://www.nextvisionstudio.com/blog/"
>
  <main class="blog-index">
    <header class="blog-index__hero">
      <div class="blog-index__kicker">NextVision Studio Blog</div>
      <h1>Clear Advice for Better Content</h1>
      <p>
        Practical guides for Dublin businesses that want video and social media
        to create trust, attention and real enquiries — without vague promises.
      </p>
    </header>

    <section class="blog-index__posts" aria-labelledby="latest-articles">
      <div class="blog-index__heading">
        <h2 id="latest-articles">Latest articles</h2>
        <span>{posts.length} {posts.length === 1 ? "guide" : "guides"}</span>
      </div>

      <div class="blog-index__grid">
        {posts.map((post) => (
          <article class="blog-card">
            <a href={"/blog/" + post.id + "/"} aria-label={"Read " + post.data.title}>
              <img
                src={post.data.heroImage}
                alt={post.data.heroAlt}
                width="1280"
                height="720"
                loading={post.data.featured ? "eager" : "lazy"}
                decoding="async"
              />
              <div class="blog-card__shade" aria-hidden="true"></div>
            </a>
            <div class="blog-card__copy">
              <div class="blog-card__meta">
                <span>{post.data.category}</span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("en-IE", { day: "numeric", month: "long", year: "numeric" })}
                </time>
                <span>{post.data.readingTime}</span>
              </div>
              <h3><a href={"/blog/" + post.id + "/"}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
              <a class="blog-card__read" href={"/blog/" + post.id + "/"}>Read the guide <span aria-hidden="true">↗</span></a>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .blog-index { min-height: 100vh; padding: 168px 24px 120px; background: radial-gradient(circle at 50% 12%, rgba(155,210,255,.1), transparent 27%), #111; color: #fff; }
  .blog-index__hero { width: min(100%, 920px); margin: 0 auto 90px; text-align: center; }
  .blog-index__kicker { display: inline-flex; margin-bottom: 22px; padding: 9px 15px; border: 1px solid rgba(180,220,255,.26); border-radius: 999px; background: rgba(155,210,255,.08); color: #cfeaff; font-size: 10px; font-weight: 900; letter-spacing: .14em; text-transform: uppercase; }
  .blog-index h1 { margin: 0; font-size: clamp(56px, 8vw, 102px); font-weight: 950; letter-spacing: -.075em; line-height: .9; }
  .blog-index__hero p { width: min(100%, 720px); margin: 27px auto 0; color: rgba(255,255,255,.65); font-size: 18px; line-height: 1.65; }
  .blog-index__posts { width: min(100%, 1120px); margin: 0 auto; }
  .blog-index__heading { display: flex; align-items: end; justify-content: space-between; margin-bottom: 28px; gap: 20px; }
  .blog-index__heading h2 { margin: 0; font-size: 31px; letter-spacing: -.05em; }
  .blog-index__heading span { color: rgba(255,255,255,.42); font-size: 12px; }
  .blog-index__grid { display: grid; gap: 25px; }
  .blog-card { display: grid; grid-template-columns: minmax(300px, .82fr) minmax(0, 1.18fr); overflow: hidden; border: 1px solid rgba(180,220,255,.15); border-radius: 28px; background: linear-gradient(145deg, #191f24, #121518); }
  .blog-card > a { position: relative; min-height: 390px; overflow: hidden; }
  .blog-card img { width: 100%; height: 100%; object-fit: cover; transition: transform 420ms ease; }
  .blog-card > a:hover img { transform: scale(1.035); }
  .blog-card__shade { position: absolute; inset: 0; background: linear-gradient(to top, rgba(10,13,16,.5), transparent 60%); }
  .blog-card__copy { display: flex; padding: clamp(30px, 5vw, 58px); flex-direction: column; justify-content: center; }
  .blog-card__meta { display: flex; flex-wrap: wrap; gap: 9px 16px; color: rgba(255,255,255,.42); font-size: 10px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; }
  .blog-card__meta span:first-child { color: #cfeaff; }
  .blog-card h3 { margin: 22px 0 0; font-size: clamp(33px, 4.4vw, 53px); letter-spacing: -.065em; line-height: .98; }
  .blog-card h3 a { text-decoration: none; }
  .blog-card__copy > p { margin: 22px 0 0; color: rgba(255,255,255,.62); font-size: 15px; line-height: 1.65; }
  .blog-card__read { margin-top: 29px; color: #cfeaff; font-size: 11px; font-weight: 900; letter-spacing: .08em; text-decoration: none; text-transform: uppercase; }
  @media (max-width: 760px) {
    .blog-index { padding: 128px 16px 90px; }
    .blog-index__hero { margin-bottom: 62px; }
    .blog-index h1 { font-size: clamp(48px, 14vw, 65px); }
    .blog-index__hero p { font-size: 16px; }
    .blog-card { grid-template-columns: 1fr; border-radius: 23px; }
    .blog-card > a { min-height: 250px; aspect-ratio: 16 / 10; }
    .blog-card__copy { padding: 28px 22px 32px; }
    .blog-card h3 { font-size: 34px; }
  }
  @media (prefers-reduced-motion: reduce) { .blog-card img { transition: none; } }
</style>
