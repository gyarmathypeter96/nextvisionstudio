---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const canonical = "https://www.nextvisionstudio.com/blog/" + post.id + "/";
const articleSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      headline: post.data.title,
      description: post.data.description,
      image: "https://www.nextvisionstudio.com" + post.data.heroImage,
      datePublished: post.data.pubDate.toISOString(),
      dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
      author: {
        "@type": "Person",
        name: post.data.author,
        url: "https://www.nextvisionstudio.com/about/",
      },
      publisher: { "@id": "https://www.nextvisionstudio.com/#business" },
      mainEntityOfPage: canonical,
      keywords: post.data.keywords.join(", "),
      inLanguage: "en-IE",
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: "https://www.nextvisionstudio.com/" },
        { "@type": "ListItem", position: 2, name: "Blog", item: "https://www.nextvisionstudio.com/blog/" },
        { "@type": "ListItem", position: 3, name: post.data.title, item: canonical },
      ],
    },
  ],
};
---

<BaseLayout
  title={post.data.title + " | NextVision Studio"}
  description={post.data.description}
  canonical={canonical}
  ogImage={post.data.heroImage}
  preloadImage={post.data.heroImage}
>
  <main class="article-page">
    <article>
      <header class="article-header">
        <nav aria-label="Breadcrumb"><a href="/blog/">Blog</a><span>/</span><span>{post.data.category}</span></nav>
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
        <div class="article-header__meta">
          <span>By <a href="/about/">{post.data.author}</a></span>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString("en-IE", { day: "numeric", month: "long", year: "numeric" })}
          </time>
          <span>{post.data.readingTime}</span>
        </div>
      </header>

      <div class="article-hero">
        <img src={post.data.heroImage} alt={post.data.heroAlt} width="1280" height="720" decoding="async" fetchpriority="high" />
      </div>

      <div class="article-layout">
        <aside aria-label="Article contents">
          <strong>In this guide</strong>
          <nav>
            {headings.filter((heading) => heading.depth === 2).map((heading) => (
              <a href={"#" + heading.slug}>{heading.text}</a>
            ))}
          </nav>
        </aside>
        <div class="article-content">
          <Content />
        </div>
      </div>
    </article>
  </main>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</BaseLayout>

<style>
  .article-page { padding: 162px 24px 120px; background: #111; color: #fff; }
  .article-page article { width: min(100%, 1160px); margin: 0 auto; }
  .article-header { width: min(100%, 940px); margin: 0 auto 48px; text-align: center; }
  .article-header nav { display: flex; justify-content: center; gap: 10px; color: rgba(255,255,255,.42); font-size: 11px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
  .article-header nav a { color: #cfeaff; text-decoration: none; }
  .article-header h1 { margin: 25px 0 0; font-size: clamp(53px, 7.5vw, 94px); font-weight: 950; letter-spacing: -.075em; line-height: .91; text-wrap: balance; }
  .article-header > p { width: min(100%, 760px); margin: 27px auto 0; color: rgba(255,255,255,.64); font-size: 18px; line-height: 1.65; }
  .article-header__meta { display: flex; flex-wrap: wrap; justify-content: center; margin-top: 25px; gap: 10px 20px; color: rgba(255,255,255,.42); font-size: 11px; }
  .article-header__meta a { color: #cfeaff; text-decoration: none; }
  .article-hero { padding: 9px; overflow: hidden; border: 1px solid rgba(180,220,255,.17); border-radius: 29px; background: rgba(255,255,255,.04); }
  .article-hero img { display: block; width: 100%; max-height: 650px; border-radius: 21px; object-fit: cover; }
  .article-layout { display: grid; grid-template-columns: 240px minmax(0, 740px); justify-content: center; margin-top: 68px; gap: 70px; }
  .article-layout > aside { position: sticky; top: 110px; height: max-content; padding: 21px; border: 1px solid rgba(180,220,255,.12); border-radius: 18px; background: rgba(255,255,255,.03); }
  .article-layout > aside strong { color: #cfeaff; font-size: 10px; letter-spacing: .12em; text-transform: uppercase; }
  .article-layout > aside nav { display: grid; margin-top: 15px; gap: 11px; }
  .article-layout > aside a { color: rgba(255,255,255,.47); font-size: 11px; line-height: 1.45; text-decoration: none; }
  .article-layout > aside a:hover { color: #fff; }
  .article-content { min-width: 0; }
  .article-content :global(p), .article-content :global(li) { color: rgba(255,255,255,.72); font-size: 17px; line-height: 1.78; }
  .article-content :global(p) { margin: 0 0 24px; }
  .article-content :global(h2) { margin: 68px 0 23px; color: #fff; font-size: clamp(34px, 4vw, 48px); letter-spacing: -.055em; line-height: 1.02; scroll-margin-top: 110px; }
  .article-content :global(h3) { margin: 38px 0 16px; color: #fff; font-size: 25px; letter-spacing: -.035em; }
  .article-content :global(ul), .article-content :global(ol) { display: grid; margin: 0 0 28px; padding-left: 24px; gap: 8px; }
  .article-content :global(a) { color: #cfeaff; text-underline-offset: 3px; }
  .article-content :global(blockquote) { margin: 34px 0; padding: 24px 27px; border-left: 3px solid #9bd2ff; border-radius: 0 18px 18px 0; background: rgba(155,210,255,.07); }
  .article-content :global(blockquote p) { margin: 0; color: #fff; font-size: 21px; font-weight: 750; line-height: 1.45; }
  .article-content :global(p:last-child a) { display: inline-flex; min-height: 54px; padding: 0 24px; align-items: center; border: 1px solid rgba(207,234,255,.4); border-radius: 999px; background: rgba(155,210,255,.1); color: #fff; font-size: 12px; font-weight: 900; letter-spacing: .07em; text-decoration: none; text-transform: uppercase; }
  @media (max-width: 880px) { .article-layout { grid-template-columns: 1fr; gap: 30px; } .article-layout > aside { position: static; } }
  @media (max-width: 640px) {
    .article-page { padding: 126px 16px 90px; }
    .article-header h1 { font-size: clamp(43px, 12vw, 58px); }
    .article-header > p { font-size: 16px; }
    .article-hero { padding: 6px; border-radius: 21px; }
    .article-hero img { min-height: 240px; border-radius: 15px; }
    .article-layout { margin-top: 44px; }
    .article-content :global(p), .article-content :global(li) { font-size: 16px; line-height: 1.72; }
    .article-content :global(h2) { margin-top: 54px; }
  }
</style>
