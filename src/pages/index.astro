---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Clients from "../components/Clients.astro";
import Stats from "../components/Stats.astro";
import Services from "../components/Services.astro";
import ContentPillar from "../components/ContentPillar.astro";
import SocialGrowthPillar from "../components/SocialGrowthPillar.astro";
import WebsitePillar from "../components/WebsitePillar.astro";
import Showreel from "../components/Showreel.astro";
import OutputFormats from "../components/OutputFormats.astro";
import QuickCall from "../components/QuickCall.astro";
import VideoPortfolio from "../components/VideoPortfolio.astro";
import PhotographyPortfolio from "../components/PhotographyPortfolio.astro";
import ContactForm from "../components/ContactForm.astro";
import GrowthCheck from "../components/GrowthCheck.astro";
import FAQ from "../components/FAQ.astro";
---

<BaseLayout
  title="NextVision Studio | Videographer Dublin"
  description="NextVision Studio is a Dublin videography and video production studio providing photography, social media content and premium website design."
  canonical="https://www.nextvisionstudio.com/"
  preloadImage="/images/hero/hero-poster.jpg"
>
  <main class="home-page">
    <Hero />
    <Clients />
    <Stats />
    <Services />
    <ContentPillar />
    <SocialGrowthPillar />
    <WebsitePillar />
    <Showreel />
    <OutputFormats />
    <QuickCall />
    <GrowthCheck />
    <VideoPortfolio />
    <PhotographyPortfolio />
    <ContactForm />
    <FAQ />
  </main>
</BaseLayout>
