---
import BaseLayout from "../layouts/BaseLayout.astro";
import LandingPage from "../components/landing/LandingPage.astro";
import { landingPages } from "../data/landingPages";

const page = landingPages.photography;
---

<BaseLayout
  title={page.metaTitle}
  description={page.metaDescription}
  canonical={`https://www.nextvisionstudio.com/${page.slug}/`}
  ogImage={`https://www.nextvisionstudio.com${page.heroImage?.src}`}
>
  <LandingPage page={page} />
</BaseLayout>
