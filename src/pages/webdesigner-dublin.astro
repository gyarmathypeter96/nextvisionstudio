---
import BaseLayout from "../layouts/BaseLayout.astro";
import LandingPage from "../components/landing/LandingPage.astro";
import { landingPages } from "../data/landingPages";

const page = landingPages.webdesign;
---

<BaseLayout
  title={page.metaTitle}
  description={page.metaDescription}
  canonical={`https://nextvisionstudio.com/${page.slug}/`}
  ogImage="https://nextvisionstudio.com/images/brand/nextvision-studio-logo.png"
>
  <LandingPage page={page} />
</BaseLayout>
