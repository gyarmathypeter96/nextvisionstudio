---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Thank You | Quote Request Received | NextVision Studio"
  description="Thank you for contacting NextVision Studio. Your quote request has been received and we will be in touch soon."
  canonical="https://www.nextvisionstudio.com/quotesend/"
  noindex={true}
>
  <main class="quote-success">
    <div class="quote-success__glow" aria-hidden="true"></div>

    <section class="quote-success__card" aria-labelledby="quote-success-title">
      <div class="quote-success__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="m6.5 12.5 3.4 3.4 7.8-8.1" />
        </svg>
      </div>

      <div class="quote-success__kicker">Message received</div>
      <h1 id="quote-success-title">Thank You for Your Enquiry</h1>
      <p class="quote-success__lead">
        Your quote request has been sent successfully. We’ll review your project
        details and get back to you as soon as possible.
      </p>

      <div class="quote-success__next">
        <span>What happens next?</span>
        <p>
          Peter from NextVision Studio will contact you to discuss your goals,
          ideas and the best next step for your project.
        </p>
      </div>

      <div class="quote-success__actions">
        <a class="quote-success__primary" href="/">Back to homepage</a>
        <a
          class="quote-success__secondary"
          href="https://wa.me/353894797055?text=Hi%20Peter%2C%20I%20have%20just%20sent%20a%20quote%20request%20through%20the%20NextVision%20Studio%20website."
          target="_blank"
          rel="noopener noreferrer"
        >
          Message on WhatsApp
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .quote-success,
  .quote-success * {
    box-sizing: border-box;
  }

  .quote-success {
    position: relative;
    display: grid;
    min-height: 100svh;
    place-items: center;
    overflow: hidden;
    padding: 56px 24px;
    background:
      radial-gradient(circle at 50% 34%, rgba(155, 210, 255, 0.13), transparent 29%),
      linear-gradient(160deg, #111111 0%, #10151a 52%, #111111 100%);
    color: #ffffff;
  }

  .quote-success__glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(820px, 92vw);
    height: min(520px, 62vh);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(155, 210, 255, 0.11), transparent 70%);
    filter: blur(46px);
    pointer-events: none;
    transform: translate(-50%, -50%);
  }

  .quote-success__card {
    position: relative;
    z-index: 1;
    width: min(100%, 760px);
    padding: clamp(34px, 6vw, 64px);
    border: 1px solid rgba(180, 220, 255, 0.2);
    border-radius: 32px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.085), rgba(255, 255, 255, 0.025)),
      rgba(18, 23, 27, 0.92);
    box-shadow:
      0 32px 100px rgba(0, 0, 0, 0.55),
      0 0 70px rgba(155, 210, 255, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.11);
    text-align: center;
  }

  .quote-success__icon {
    display: grid;
    width: 74px;
    height: 74px;
    margin: 0 auto 25px;
    place-items: center;
    border: 1px solid rgba(180, 220, 255, 0.32);
    border-radius: 50%;
    background: rgba(155, 210, 255, 0.12);
    box-shadow:
      0 0 34px rgba(155, 210, 255, 0.16),
      inset 0 1px 1px rgba(255, 255, 255, 0.24);
    color: #d7efff;
  }

  .quote-success__icon svg {
    width: 36px;
    height: 36px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .quote-success__kicker {
    display: inline-flex;
    margin-bottom: 19px;
    padding: 9px 15px;
    border: 1px solid rgba(180, 220, 255, 0.23);
    border-radius: 999px;
    background: rgba(155, 210, 255, 0.07);
    color: #cfeaff;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
  }

  .quote-success h1 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(42px, 7vw, 68px);
    font-weight: 900;
    letter-spacing: -0.06em;
    line-height: 0.98;
    text-wrap: balance;
  }

  .quote-success__lead {
    width: min(100%, 590px);
    margin: 24px auto 0;
    color: rgba(255, 255, 255, 0.69);
    font-size: clamp(16px, 2.2vw, 19px);
    font-weight: 500;
    line-height: 1.6;
    text-wrap: balance;
  }

  .quote-success__next {
    width: min(100%, 590px);
    margin: 30px auto 0;
    padding: 20px 22px;
    border: 1px solid rgba(180, 220, 255, 0.12);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.035);
  }

  .quote-success__next span {
    display: block;
    margin-bottom: 7px;
    color: #d7efff;
    font-size: 13px;
    font-weight: 850;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .quote-success__next p {
    margin: 0;
    color: rgba(255, 255, 255, 0.6);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.55;
  }

  .quote-success__actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 31px;
  }

  .quote-success__actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    padding: 0 25px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 850;
    letter-spacing: 0.035em;
    text-decoration: none;
    transition:
      border-color 220ms ease,
      background 220ms ease,
      box-shadow 220ms ease,
      transform 220ms ease;
  }

  .quote-success__primary {
    border: 1px solid rgba(210, 235, 255, 0.38);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.17), rgba(155, 210, 255, 0.1)),
      rgba(255, 255, 255, 0.075);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.27),
      0 15px 36px rgba(0, 0, 0, 0.28);
    color: #ffffff;
  }

  .quote-success__secondary {
    border: 1px solid rgba(180, 220, 255, 0.15);
    background: rgba(255, 255, 255, 0.035);
    color: rgba(255, 255, 255, 0.78);
  }

  .quote-success__actions a:hover {
    border-color: rgba(210, 235, 255, 0.46);
    background-color: rgba(155, 210, 255, 0.11);
    box-shadow: 0 0 28px rgba(155, 210, 255, 0.1);
    transform: translateY(-2px);
  }

  .quote-success__actions a:focus-visible {
    outline: 3px solid #cfeaff;
    outline-offset: 4px;
  }

  @media (max-width: 600px) {
    .quote-success {
      padding: 30px 16px;
    }

    .quote-success__card {
      padding: 35px 20px 26px;
      border-radius: 25px;
    }

    .quote-success__icon {
      width: 64px;
      height: 64px;
      margin-bottom: 21px;
    }

    .quote-success__actions {
      flex-direction: column;
    }

    .quote-success__actions a {
      width: 100%;
    }
  }

  @media (max-height: 760px) and (min-width: 601px) {
    .quote-success {
      padding: 22px 24px;
    }

    .quote-success__card {
      padding: 28px 48px;
    }

    .quote-success__icon {
      width: 54px;
      height: 54px;
      margin-bottom: 13px;
    }

    .quote-success__icon svg {
      width: 28px;
      height: 28px;
    }

    .quote-success__kicker {
      margin-bottom: 13px;
    }

    .quote-success h1 {
      font-size: clamp(42px, 5.3vw, 58px);
    }

    .quote-success__lead {
      margin-top: 16px;
      line-height: 1.48;
    }

    .quote-success__next {
      margin-top: 18px;
      padding: 14px 20px;
    }

    .quote-success__actions {
      margin-top: 18px;
    }

    .quote-success__actions a {
      min-height: 48px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .quote-success__actions a {
      transition: none;
    }
  }
</style>
